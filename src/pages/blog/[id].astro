---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const publishDate = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Per-post OG image — rendered on-demand at /blog/<slug>/og.png so
// social previews show the actual post title, not the generic brand
// card. Falls back to the post's frontmatter image (if set) or the
// brand image (Layout default) when the dynamic image errors out.
const ogImage = post.data.image ?? `https://lovefarfox.com/blog/${post.id}/og.png`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": post.data.title,
  "description": post.data.description,
  "datePublished": post.data.date,
  "image": ogImage,
  "author": {
    "@type": "Organization",
    "name": "Far Fox",
    "url": "https://lovefarfox.com",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Far Fox",
    "logo": {
      "@type": "ImageObject",
      "url": "https://lovefarfox.com/fox-logo.png",
    },
  },
};

// FAQPage rich-snippet schema — only emitted when the post declares
// `faqs` in frontmatter. Google can render these as expandable Q&A
// dropdowns directly in search results, which typically lifts CTR
// significantly on question-targeted queries.
const faqs = post.data.faqs;
const faqSchema = faqs && faqs.length > 0
  ? {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqs.map((f) => ({
        "@type": "Question",
        "name": f.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": f.answer,
        },
      })),
    }
  : null;
---

<Layout title={`${post.data.title} — Far Fox`} description={post.data.description} image={ogImage}>
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <nav class="fixed top-0 w-full z-50 backdrop-blur-md bg-fox-bg/80 border-b border-fox-pink/10">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/fox-logo.png" alt="Far Fox" class="w-8 h-8" />
        <span class="text-xl font-900 tracking-tight bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">
          Far Fox
        </span>
      </a>
      <a
        href="https://app.lovefarfox.com"
        class="px-5 py-2 rounded-full bg-gradient-to-r from-fox-pink to-fox-purple text-white font-700 text-sm hover:shadow-lg hover:shadow-fox-pink/25 transition-all duration-200 hover:-translate-y-0.5"
      >
        Open App
      </a>
    </div>
  </nav>

  <main class="pt-28 pb-24 px-6">
    <article class="max-w-3xl mx-auto">
      <a href="/blog" class="inline-flex items-center gap-1 text-sm text-fox-text-light/60 hover:text-fox-pink transition-colors mb-8">
        &larr; Back to blog
      </a>

      <h1 class="text-3xl sm:text-4xl font-900 tracking-tight leading-tight mb-4">{post.data.title}</h1>
      <p class="text-fox-text-light mb-10">{publishDate}</p>

      <div class="prose prose-lg max-w-none
        prose-headings:font-800 prose-headings:tracking-tight prose-headings:text-fox-text
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4
        prose-p:text-fox-text-light prose-p:leading-relaxed
        prose-a:text-fox-pink prose-a:font-700 prose-a:no-underline hover:prose-a:underline
        prose-strong:text-fox-text prose-strong:font-800
        prose-li:text-fox-text-light
        prose-hr:border-fox-pink/10
      ">
        <Content />
      </div>

      {faqs && faqs.length > 0 && (
        <section class="mt-16">
          <h2 class="text-2xl font-800 tracking-tight mb-6">FAQs</h2>
          <div class="space-y-4">
            {faqs.map((f) => (
              <details class="group rounded-2xl bg-white/70 border border-fox-pink/8 hover:border-fox-pink/20 transition-all duration-200">
                <summary class="flex items-start justify-between p-5 cursor-pointer font-800 text-lg list-none [&::-webkit-details-marker]:hidden">
                  <span>{f.question}</span>
                  <span class="ml-4 text-fox-pink/40 group-open:rotate-45 transition-transform duration-200 text-2xl font-700">+</span>
                </summary>
                <div class="px-5 pb-5 text-fox-text-light leading-relaxed">
                  {f.answer}
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      <div class="mt-16 p-8 rounded-2xl bg-gradient-to-r from-fox-pink/5 to-fox-purple/5 border border-fox-pink/10 text-center">
        <p class="font-800 text-xl mb-2">Make distance feel smaller</p>
        <p class="text-fox-text-light mb-6">Daily photos, love letters, questions, and a fox that grows with your love.</p>
        <a
          href="https://app.lovefarfox.com"
          class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-fox-pink to-fox-purple text-white font-800 hover:shadow-xl hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5"
        >
          Try Far Fox Free
        </a>
      </div>
    </article>
  </main>

  <footer class="py-12 px-6 border-t border-fox-pink/10">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-800 text-lg bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">Far Fox</span>
      <div class="flex items-center gap-6 text-sm text-fox-text-light/50">
        <a href="/blog" class="hover:text-fox-pink transition-colors">Blog</a>
        <a href="/privacy" class="hover:text-fox-pink transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-fox-pink transition-colors">Terms</a>
        <a href="mailto:blake@lovefarfox.com" class="hover:text-fox-pink transition-colors">Contact</a>
        <span>&copy; {new Date().getFullYear()} Far Fox</span>
      </div>
    </div>
  </footer>
</Layout>
