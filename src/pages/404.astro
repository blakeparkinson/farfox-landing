---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Lost in the Distance | Far Fox" description="This page doesn't exist, but you found a game! Help your fox catch hearts.">
  <canvas id="scene" style="position:fixed;inset:0;z-index:0;touch-action:none;"></canvas>

  <div class="fixed inset-x-0 bottom-0 z-10 flex flex-col items-center pb-8 sm:pb-12 pointer-events-none">
    <div class="pointer-events-auto text-center px-6">
      <a
        href="/"
        class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-fox-pink to-fox-purple text-white font-800 hover:shadow-xl hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5 text-sm sm:text-base"
      >
        Take Me Home
      </a>
    </div>
  </div>

  <script is:inline>
  (function() {
    const C = document.getElementById('scene');
    const X = C.getContext('2d');
    let W, H, dpr;

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = window.innerWidth;
      H = window.innerHeight;
      C.width = W * dpr;
      C.height = H * dpr;
      C.style.width = W + 'px';
      C.style.height = H + 'px';
      X.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    // Assets
    const foxImg = new Image();
    foxImg.src = '/fox-logo.png';
    let foxReady = false;
    foxImg.onload = () => { foxReady = true; };

    // Easing
    function lerp(a, b, t) { return a + (b - a) * t; }
    function ease(t) { return t < 0.5 ? 4*t*t*t : 1-Math.pow(-2*t+2,3)/2; }

    // ---- SCENE OBJECTS ----

    // Starfield — 3 layers for parallax
    const starLayers = [[], [], []];
    const layerSpeeds = [0.01, 0.025, 0.05];
    for (let layer = 0; layer < 3; layer++) {
      const count = layer === 0 ? 80 : layer === 1 ? 50 : 30;
      for (let i = 0; i < count; i++) {
        starLayers[layer].push({
          x: Math.random(),
          y: Math.random(),
          size: (layer + 1) * 0.6 + Math.random() * 0.8,
          twinkle: Math.random() * Math.PI * 2,
          speed: 0.5 + Math.random() * 2,
          hue: Math.random() > 0.9 ? (Math.random() > 0.5 ? '#FF6B8A' : '#B76CFD') : '#fff',
        });
      }
    }

    // Nebula blobs — soft colored gradient spheres
    const nebulae = [];
    const nebulaColors = [
      { r: 255, g: 107, b: 138 }, // pink
      { r: 183, g: 108, b: 253 }, // purple
      { r: 255, g: 154, b: 92 },  // orange
      { r: 99, g: 102, b: 241 },  // indigo
      { r: 139, g: 92, b: 246 },  // violet
    ];
    for (let i = 0; i < 5; i++) {
      nebulae.push({
        x: 0.1 + Math.random() * 0.8,
        y: 0.1 + Math.random() * 0.8,
        radius: 120 + Math.random() * 200,
        color: nebulaColors[i],
        alpha: 0.04 + Math.random() * 0.04,
        drift: { x: (Math.random() - 0.5) * 0.00015, y: (Math.random() - 0.5) * 0.00015 },
        parallax: 0.02 + Math.random() * 0.03,
      });
    }

    // Floating hearts
    const hearts = [];
    function spawnHeart() {
      hearts.push({
        x: Math.random() * W,
        y: H + 30,
        size: 12 + Math.random() * 18,
        speed: 0.3 + Math.random() * 0.6,
        wobbleAmp: 20 + Math.random() * 30,
        wobbleSpeed: 0.5 + Math.random() * 1,
        wobbleOffset: Math.random() * Math.PI * 2,
        rotation: (Math.random() - 0.5) * 0.4,
        rotSpeed: (Math.random() - 0.5) * 0.01,
        opacity: 0.3 + Math.random() * 0.4,
        color: ['#FF6B8A', '#B76CFD', '#FF9A5C', '#F472B6', '#E879F9', '#FFB6C1'][Math.floor(Math.random() * 6)],
        popped: false,
        popScale: 1,
        popAlpha: 1,
      });
    }
    // Seed initial hearts
    for (let i = 0; i < 12; i++) {
      spawnHeart();
      hearts[i].y = Math.random() * H;
    }

    // Pop particles
    const pops = [];
    function popHeart(h) {
      h.popped = true;
      h.popScale = 1;
      h.popAlpha = 1;
      for (let i = 0; i < 8; i++) {
        const a = (Math.PI * 2 / 8) * i + Math.random() * 0.4;
        pops.push({
          x: h.x, y: h.y,
          vx: Math.cos(a) * (1.5 + Math.random() * 2),
          vy: Math.sin(a) * (1.5 + Math.random() * 2),
          size: 2 + Math.random() * 3,
          life: 1,
          color: h.color,
        });
      }
    }

    // Fox state
    const fox = {
      x: W / 2, y: H * 0.55,
      vx: 0, vy: 0,
      targetX: W / 2, targetY: H * 0.55,
      size: Math.min(100, W * 0.12),
      rotation: 0,
      squash: 1, stretch: 1,
      bobPhase: 0,
    };

    // Mouse / touch
    let mx = W / 2, my = H / 2;
    let mouseActive = false;

    C.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; mouseActive = true; });
    C.addEventListener('click', e => {
      fox.targetX = e.clientX;
      fox.targetY = e.clientY;
      mouseActive = true;
    });
    C.addEventListener('touchstart', e => {
      e.preventDefault();
      const t = e.touches[0];
      mx = t.clientX; my = t.clientY;
      fox.targetX = t.clientX;
      fox.targetY = t.clientY;
      mouseActive = true;
    });
    C.addEventListener('touchmove', e => {
      e.preventDefault();
      const t = e.touches[0];
      mx = t.clientX; my = t.clientY;
    });

    // ---- DRAWING HELPERS ----

    function drawHeart(cx, cy, size, color, alpha) {
      X.save();
      X.globalAlpha = alpha;
      X.translate(cx, cy);
      X.beginPath();
      const s = size;
      X.moveTo(0, s * 0.3);
      X.bezierCurveTo(-s*0.05, s*0.1, -s*0.5, -s*0.1, -s*0.5, -s*0.3);
      X.bezierCurveTo(-s*0.5, -s*0.55, -s*0.25, -s*0.7, 0, -s*0.5);
      X.bezierCurveTo(s*0.25, -s*0.7, s*0.5, -s*0.55, s*0.5, -s*0.3);
      X.bezierCurveTo(s*0.5, -s*0.1, s*0.05, s*0.1, 0, s*0.3);
      X.closePath();
      X.shadowColor = color;
      X.shadowBlur = 12;
      const g = X.createRadialGradient(-s*0.1, -s*0.25, 0, 0, 0, s*0.55);
      g.addColorStop(0, lighten(color, 60));
      g.addColorStop(1, color);
      X.fillStyle = g;
      X.fill();
      X.shadowBlur = 0;
      // highlight
      X.beginPath();
      X.ellipse(-s*0.15, -s*0.32, s*0.08, s*0.05, -0.5, 0, Math.PI*2);
      X.fillStyle = `rgba(255,255,255,${0.5 * alpha})`;
      X.fill();
      X.restore();
    }

    function lighten(hex, amt) {
      const r = Math.min(255, parseInt(hex.slice(1,3),16) + amt);
      const g = Math.min(255, parseInt(hex.slice(3,5),16) + amt);
      const b = Math.min(255, parseInt(hex.slice(5,7),16) + amt);
      return `rgb(${r},${g},${b})`;
    }

    // ---- MAIN LOOP ----
    let t = 0;
    let lastNow = performance.now();
    let heartTimer = 0;

    function frame(now) {
      requestAnimationFrame(frame);
      const rawDt = (now - lastNow) / 1000;
      const dt = Math.min(rawDt, 0.05);
      lastNow = now;
      t += dt;
      heartTimer += dt;

      X.clearRect(0, 0, W, H);

      // --- SKY ---
      const sky = X.createLinearGradient(0, 0, 0, H);
      sky.addColorStop(0, '#0a0618');
      sky.addColorStop(0.4, '#120a2e');
      sky.addColorStop(0.7, '#1a1040');
      sky.addColorStop(1, '#0e0825');
      X.fillStyle = sky;
      X.fillRect(0, 0, W, H);

      // Parallax offset from mouse
      const px = (mx / W - 0.5) * 2;
      const py = (my / H - 0.5) * 2;

      // --- NEBULAE ---
      nebulae.forEach(n => {
        n.x += n.drift.x;
        n.y += n.drift.y;
        if (n.x < -0.1 || n.x > 1.1) n.drift.x *= -1;
        if (n.y < -0.1 || n.y > 1.1) n.drift.y *= -1;
        const nx = n.x * W + px * n.parallax * W;
        const ny = n.y * H + py * n.parallax * H;
        const g = X.createRadialGradient(nx, ny, 0, nx, ny, n.radius);
        g.addColorStop(0, `rgba(${n.color.r},${n.color.g},${n.color.b},${n.alpha})`);
        g.addColorStop(1, `rgba(${n.color.r},${n.color.g},${n.color.b},0)`);
        X.fillStyle = g;
        X.fillRect(0, 0, W, H);
      });

      // --- STARS with parallax ---
      starLayers.forEach((stars, li) => {
        const pxFactor = layerSpeeds[li];
        stars.forEach(s => {
          const twinkle = 0.4 + 0.6 * (Math.sin(t * s.speed + s.twinkle) * 0.5 + 0.5);
          X.globalAlpha = twinkle;
          X.fillStyle = s.hue;
          const sx = s.x * W + px * pxFactor * W;
          const sy = s.y * H + py * pxFactor * H;
          X.beginPath();
          X.arc(sx, sy, s.size, 0, Math.PI * 2);
          X.fill();
        });
      });
      X.globalAlpha = 1;

      // --- FLOATING HEARTS ---
      hearts.forEach(h => {
        if (h.popped) {
          h.popScale += dt * 3;
          h.popAlpha -= dt * 3;
          if (h.popAlpha > 0) {
            X.save();
            X.translate(h.x, h.y);
            X.scale(h.popScale, h.popScale);
            X.rotate(h.rotation);
            drawHeart(0, 0, h.size, h.color, h.popAlpha * 0.5);
            X.restore();
          }
          return;
        }

        h.y -= h.speed;
        h.x += Math.sin(t * h.wobbleSpeed + h.wobbleOffset) * h.wobbleAmp * dt;
        h.rotation += h.rotSpeed;

        // Fade in at bottom, fade out at top
        const fadeIn = Math.min(1, (H - h.y) / 100);
        const fadeOut = Math.min(1, h.y / 100);
        const alpha = h.opacity * fadeIn * fadeOut;

        X.save();
        X.translate(h.x, h.y);
        X.rotate(h.rotation);
        drawHeart(0, 0, h.size, h.color, alpha);
        X.restore();

        // Check if fox touches this heart
        const dx = fox.x - h.x;
        const dy = fox.y - h.y;
        if (Math.sqrt(dx*dx + dy*dy) < fox.size * 0.4 + h.size * 0.3) {
          popHeart(h);
        }
      });

      // Remove dead hearts and spawn new
      for (let i = hearts.length - 1; i >= 0; i--) {
        if (hearts[i].y < -40 || (hearts[i].popped && hearts[i].popAlpha <= 0)) {
          hearts.splice(i, 1);
        }
      }
      if (heartTimer > 0.8 && hearts.length < 15) {
        spawnHeart();
        heartTimer = 0;
      }

      // --- POP PARTICLES ---
      for (let i = pops.length - 1; i >= 0; i--) {
        const p = pops[i];
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.05;
        p.vx *= 0.98;
        p.life -= dt * 2.5;
        if (p.life <= 0) { pops.splice(i, 1); continue; }
        X.globalAlpha = p.life;
        X.fillStyle = p.color;
        X.beginPath();
        X.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
        X.fill();
      }
      X.globalAlpha = 1;

      // --- FOX ---
      // Smooth follow toward target (which updates on click) or gentle drift
      if (mouseActive) {
        const dx = fox.targetX - fox.x;
        const dy = fox.targetY - fox.y;
        const dist = Math.sqrt(dx*dx + dy*dy);
        if (dist > 2) {
          const speed = Math.min(dist * 0.04, 8);
          fox.vx += (dx / dist) * speed * dt * 60;
          fox.vy += (dy / dist) * speed * dt * 60;
        }
      }
      // Gentle ambient drift
      fox.vx += Math.sin(t * 0.3) * 0.02;
      fox.vy += Math.cos(t * 0.4) * 0.02;

      // Damping
      fox.vx *= 0.92;
      fox.vy *= 0.92;

      fox.x += fox.vx;
      fox.y += fox.vy;

      // Soft bounds
      fox.x = Math.max(fox.size * 0.6, Math.min(W - fox.size * 0.6, fox.x));
      fox.y = Math.max(fox.size * 0.6, Math.min(H - fox.size * 1.5, fox.y));

      // Squash & stretch based on speed
      const spd = Math.sqrt(fox.vx*fox.vx + fox.vy*fox.vy);
      fox.stretch = lerp(fox.stretch, spd > 0.5 ? 1 + spd * 0.02 : 1, 0.1);
      fox.squash = lerp(fox.squash, spd > 0.5 ? 1 - spd * 0.015 : 1, 0.1);

      // Tilt toward movement
      const targetRot = Math.atan2(fox.vy, fox.vx) * 0.12;
      fox.rotation = lerp(fox.rotation, spd > 0.3 ? targetRot : 0, 0.08);

      fox.bobPhase += dt * 2;
      const bob = Math.sin(fox.bobPhase) * 5;

      if (foxReady) {
        X.save();
        X.translate(fox.x, fox.y + bob);
        X.rotate(fox.rotation);
        X.scale(fox.stretch, fox.squash);

        // Warm glow
        const glow = X.createRadialGradient(0, 0, fox.size * 0.15, 0, 0, fox.size * 0.75);
        glow.addColorStop(0, 'rgba(255,154,92,0.25)');
        glow.addColorStop(0.5, 'rgba(255,107,138,0.08)');
        glow.addColorStop(1, 'rgba(183,108,253,0)');
        X.fillStyle = glow;
        X.beginPath();
        X.arc(0, 0, fox.size * 0.75, 0, Math.PI * 2);
        X.fill();

        // Fox
        const s = fox.size;
        X.drawImage(foxImg, -s/2, -s/2, s, s);
        X.restore();
      }

      // --- 404 TEXT ---
      X.save();
      X.textAlign = 'center';

      const centerY = Math.min(H * 0.22, 200);
      const fs = Math.min(Math.max(W * 0.18, 80), 200);
      X.font = `900 ${fs}px Nunito, sans-serif`;

      // Text shadow layers for depth
      X.shadowColor = 'rgba(183,108,253,0.4)';
      X.shadowBlur = 60;
      const tg = X.createLinearGradient(W/2 - fs, centerY, W/2 + fs, centerY);
      tg.addColorStop(0, '#FF6B8A');
      tg.addColorStop(0.5, '#B76CFD');
      tg.addColorStop(1, '#FF9A5C');
      X.fillStyle = tg;
      X.fillText('404', W/2, centerY);

      // Second pass for extra glow
      X.shadowColor = 'rgba(255,107,138,0.3)';
      X.shadowBlur = 80;
      X.fillText('404', W/2, centerY);
      X.shadowBlur = 0;

      // Subtitle
      const ss = Math.min(Math.max(W * 0.028, 16), 30);
      X.font = `700 ${ss}px Nunito, sans-serif`;
      X.fillStyle = 'rgba(255,255,255,0.75)';
      X.shadowColor = 'rgba(0,0,0,0.3)';
      X.shadowBlur = 6;
      X.fillText("Looks like you've wandered too far, little fox", W/2, centerY + fs * 0.32);
      X.shadowBlur = 0;

      // Hint — pulses gently
      if (!mouseActive) {
        X.globalAlpha = 0.35 + Math.sin(t * 1.5) * 0.15;
        X.font = `600 ${Math.max(13, ss * 0.65)}px Nunito, sans-serif`;
        X.fillStyle = 'rgba(255,255,255,0.6)';
        X.fillText('tap or click to guide the fox', W/2, centerY + fs * 0.52);
        X.globalAlpha = 1;
      }

      X.restore();
    }

    requestAnimationFrame(frame);
  })();
  </script>
</Layout>
