---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Lost in the Distance | Far Fox" description="This page doesn't exist. Your fox is waiting for you back home.">
  <div id="scene-container"></div>

  <!-- UI overlay -->
  <div id="ui-overlay" class="fixed inset-0 z-10 flex flex-col items-center justify-end pb-16 pointer-events-none">
    <div class="pointer-events-auto text-center px-6">
      <p id="score-display" class="text-white/0 text-sm font-700 mb-2 transition-all duration-500"></p>
      <p class="text-7xl sm:text-8xl font-900 bg-gradient-to-r from-fox-pink via-fox-purple to-fox-orange bg-clip-text text-transparent mb-1 select-none">
        404
      </p>
      <h1 class="text-xl sm:text-2xl font-800 text-white mb-2 drop-shadow-lg">
        Lost in the distance
      </h1>
      <p id="hint-text" class="text-white/50 text-sm mb-6 max-w-sm mx-auto drop-shadow transition-all duration-500">
        Click anywhere to help your fox catch hearts
      </p>
      <a
        href="/"
        class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-fox-pink to-fox-purple text-white font-800 hover:shadow-xl hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5"
      >
        Take Me Home
      </a>
    </div>
  </div>

  <script is:inline>
    const script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js';
    script.onload = () => init();
    document.head.appendChild(script);

    function init() {
      const THREE = window.THREE;
      const container = document.getElementById('scene-container');
      container.style.cssText = 'position:fixed;inset:0;z-index:0;cursor:crosshair;';

      const scene = new THREE.Scene();
      const camera = new THREE.PerspectiveCamera(60, innerWidth / innerHeight, 0.1, 1000);
      camera.position.z = 30;

      const renderer = new THREE.WebGLRenderer({ antialias: true });
      renderer.setSize(innerWidth, innerHeight);
      renderer.setPixelRatio(Math.min(devicePixelRatio, 2));
      renderer.setClearColor(0x0f0a2e);
      container.appendChild(renderer.domElement);

      // Game state
      let score = 0;
      let foxVx = 0, foxVy = 0;
      let foxTargetX = 0, foxTargetY = -1;
      let isChasing = false;
      let chasedHeart = null;
      let combo = 0;
      let lastCatchTime = 0;
      let foxSpin = 0;
      let foxSquash = 1;
      let mouthOpen = 0;
      const particles = [];
      const scoreEl = document.getElementById('score-display');
      const hintEl = document.getElementById('hint-text');

      // Starfield with colors
      const starCount = 2000;
      const starGeo = new THREE.BufferGeometry();
      const starPos = new Float32Array(starCount * 3);
      const starColors = new Float32Array(starCount * 3);
      const starSizes = new Float32Array(starCount);
      for (let i = 0; i < starCount; i++) {
        starPos[i * 3] = (Math.random() - 0.5) * 300;
        starPos[i * 3 + 1] = (Math.random() - 0.5) * 300;
        starPos[i * 3 + 2] = (Math.random() - 0.5) * 300;
        starSizes[i] = Math.random() * 2.5 + 0.5;
        // Mostly white, some pink/purple
        const tint = Math.random();
        if (tint > 0.9) { starColors[i*3]=1; starColors[i*3+1]=0.42; starColors[i*3+2]=0.54; }
        else if (tint > 0.8) { starColors[i*3]=0.72; starColors[i*3+1]=0.42; starColors[i*3+2]=0.99; }
        else { starColors[i*3]=1; starColors[i*3+1]=1; starColors[i*3+2]=1; }
      }
      starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
      starGeo.setAttribute('color', new THREE.BufferAttribute(starColors, 3));
      starGeo.setAttribute('size', new THREE.BufferAttribute(starSizes, 1));

      const starMat = new THREE.ShaderMaterial({
        uniforms: { uTime: { value: 0 } },
        vertexShader: `
          attribute float size;
          attribute vec3 color;
          uniform float uTime;
          varying float vAlpha;
          varying vec3 vColor;
          void main() {
            vColor = color;
            vec3 pos = position;
            pos.z = mod(pos.z + uTime * 12.0, 300.0) - 150.0;
            vAlpha = smoothstep(-150.0, -20.0, pos.z) * (0.4 + 0.6 * sin(uTime * 3.0 + position.x * 0.05 + position.y * 0.07));
            vec4 mvPos = modelViewMatrix * vec4(pos, 1.0);
            gl_PointSize = size * (100.0 / -mvPos.z);
            gl_Position = projectionMatrix * mvPos;
          }
        `,
        fragmentShader: `
          varying float vAlpha;
          varying vec3 vColor;
          void main() {
            float d = length(gl_PointCoord - 0.5);
            if (d > 0.5) discard;
            float glow = smoothstep(0.5, 0.0, d);
            gl_FragColor = vec4(vColor, vAlpha * glow * glow);
          }
        `,
        transparent: true,
        depthWrite: false,
        vertexColors: true,
      });
      scene.add(new THREE.Points(starGeo, starMat));

      // === FOX ===
      const foxGroup = new THREE.Group();
      const foxBody = new THREE.Group();
      foxGroup.add(foxBody);
      scene.add(foxGroup);

      const foxOrange = 0xFF9A5C;
      const foxPink = 0xFF6B8A;
      const foxWhite = 0xFFFFFF;
      const foxDark = 0x2D1B4E;

      // Head
      const head = new THREE.Mesh(
        new THREE.SphereGeometry(3, 32, 32),
        new THREE.MeshStandardMaterial({ color: foxOrange, roughness: 0.7 })
      );
      foxBody.add(head);

      // Face patch
      const face = new THREE.Mesh(
        new THREE.SphereGeometry(2.3, 32, 32),
        new THREE.MeshStandardMaterial({ color: foxWhite, roughness: 0.7 })
      );
      face.position.z = 0.9;
      foxBody.add(face);

      // Forehead patch
      const forehead = new THREE.Mesh(
        new THREE.SphereGeometry(1.2, 16, 16),
        new THREE.MeshStandardMaterial({ color: 0xFFCBA4, roughness: 0.8 })
      );
      forehead.position.set(0, 1.2, 1.8);
      forehead.scale.set(1.3, 0.5, 0.5);
      foxBody.add(forehead);

      // Eyes — bigger, more expressive
      const eyeWhiteGeo = new THREE.SphereGeometry(0.6, 16, 16);
      const eyeWhiteMat = new THREE.MeshStandardMaterial({ color: foxWhite, roughness: 0.3 });
      const leftEyeWhite = new THREE.Mesh(eyeWhiteGeo, eyeWhiteMat);
      leftEyeWhite.position.set(-0.9, 0.4, 2.1);
      foxBody.add(leftEyeWhite);
      const rightEyeWhite = new THREE.Mesh(eyeWhiteGeo, eyeWhiteMat);
      rightEyeWhite.position.set(0.9, 0.4, 2.1);
      foxBody.add(rightEyeWhite);

      const pupilGeo = new THREE.SphereGeometry(0.38, 16, 16);
      const pupilMat = new THREE.MeshStandardMaterial({ color: foxDark, roughness: 0.2 });
      const leftPupil = new THREE.Mesh(pupilGeo, pupilMat);
      leftPupil.position.set(-0.9, 0.4, 2.55);
      foxBody.add(leftPupil);
      const rightPupil = new THREE.Mesh(pupilGeo, pupilMat);
      rightPupil.position.set(0.9, 0.4, 2.55);
      foxBody.add(rightPupil);

      // Eye highlights
      const hlGeo = new THREE.SphereGeometry(0.14, 8, 8);
      const hlMat = new THREE.MeshBasicMaterial({ color: 0xFFFFFF });
      const lhl = new THREE.Mesh(hlGeo, hlMat);
      lhl.position.set(-0.72, 0.58, 2.75);
      foxBody.add(lhl);
      const rhl = new THREE.Mesh(hlGeo, hlMat);
      rhl.position.set(1.08, 0.58, 2.75);
      foxBody.add(rhl);

      // Nose
      const nose = new THREE.Mesh(
        new THREE.SphereGeometry(0.22, 12, 12),
        new THREE.MeshStandardMaterial({ color: foxDark, roughness: 0.3 })
      );
      nose.position.set(0, -0.2, 2.7);
      nose.scale.set(1.2, 0.8, 0.8);
      foxBody.add(nose);

      // Mouth — opens when catching
      const mouthGeo = new THREE.SphereGeometry(0.3, 12, 12);
      const mouthMat = new THREE.MeshStandardMaterial({ color: 0xE8557A, roughness: 0.5 });
      const mouth = new THREE.Mesh(mouthGeo, mouthMat);
      mouth.position.set(0, -0.55, 2.4);
      mouth.scale.set(1.2, 0, 0.5);
      foxBody.add(mouth);

      // Tongue (hidden, shows on catch)
      const tongue = new THREE.Mesh(
        new THREE.SphereGeometry(0.15, 8, 8),
        new THREE.MeshStandardMaterial({ color: 0xFF8FAB, roughness: 0.5 })
      );
      tongue.position.set(0, -0.75, 2.5);
      tongue.scale.set(1, 0, 1);
      foxBody.add(tongue);

      // Blush
      const blushGeo = new THREE.SphereGeometry(0.5, 16, 16);
      const blushMat = new THREE.MeshStandardMaterial({ color: foxPink, roughness: 0.9, transparent: true, opacity: 0.35 });
      const lb = new THREE.Mesh(blushGeo, blushMat);
      lb.position.set(-1.6, -0.2, 1.9);
      lb.scale.set(1, 0.6, 0.5);
      foxBody.add(lb);
      const rb = new THREE.Mesh(blushGeo, blushMat);
      rb.position.set(1.6, -0.2, 1.9);
      rb.scale.set(1, 0.6, 0.5);
      foxBody.add(rb);

      // Ears
      const earGeo = new THREE.ConeGeometry(1.3, 2.5, 4);
      const earMat = new THREE.MeshStandardMaterial({ color: foxOrange, roughness: 0.7 });
      const innerEarGeo = new THREE.ConeGeometry(0.65, 1.3, 4);
      const innerEarMat = new THREE.MeshStandardMaterial({ color: foxPink, roughness: 0.7 });

      const le = new THREE.Mesh(earGeo, earMat);
      le.position.set(-1.9, 2.9, 0);
      le.rotation.z = 0.3;
      foxBody.add(le);
      const lei = new THREE.Mesh(innerEarGeo, innerEarMat);
      lei.position.set(-1.9, 3.0, 0.3);
      lei.rotation.z = 0.3;
      foxBody.add(lei);
      const re = new THREE.Mesh(earGeo, earMat);
      re.position.set(1.9, 2.9, 0);
      re.rotation.z = -0.3;
      foxBody.add(re);
      const rei = new THREE.Mesh(innerEarGeo, innerEarMat);
      rei.position.set(1.9, 3.0, 0.3);
      rei.rotation.z = -0.3;
      foxBody.add(rei);

      foxGroup.position.set(0, -1, 0);

      // === HEARTS (collectibles) ===
      const hearts = [];
      const heartShape = new THREE.Shape();
      heartShape.moveTo(0, 0.5);
      heartShape.bezierCurveTo(0, 0.5, -0.5, 0, -0.5, 0);
      heartShape.bezierCurveTo(-0.5, -0.35, 0, -0.7, 0, -0.95);
      heartShape.bezierCurveTo(0, -0.7, 0.5, -0.35, 0.5, 0);
      heartShape.bezierCurveTo(0.5, 0, 0, 0.5, 0, 0.5);

      const heartGeo = new THREE.ExtrudeGeometry(heartShape, {
        depth: 0.2, bevelEnabled: true, bevelThickness: 0.08,
        bevelSize: 0.08, bevelSegments: 4,
      });

      const heartColors = [0xFF6B8A, 0xB76CFD, 0xFF9A5C, 0xFFB6C1, 0xF472B6];

      function spawnHeart() {
        const color = heartColors[Math.floor(Math.random() * heartColors.length)];
        const mat = new THREE.MeshStandardMaterial({
          color, roughness: 0.3, metalness: 0.2,
          emissive: color, emissiveIntensity: 0.15,
        });
        const heart = new THREE.Mesh(heartGeo, mat);
        const scale = 0.5 + Math.random() * 0.6;
        heart.scale.set(scale, scale, scale);

        // Spawn from edges
        const side = Math.floor(Math.random() * 4);
        if (side === 0) heart.position.set(-28, (Math.random()-0.5)*20, (Math.random()-0.5)*10);
        else if (side === 1) heart.position.set(28, (Math.random()-0.5)*20, (Math.random()-0.5)*10);
        else if (side === 2) heart.position.set((Math.random()-0.5)*40, 18, (Math.random()-0.5)*10);
        else heart.position.set((Math.random()-0.5)*40, -18, (Math.random()-0.5)*10);

        heart.userData = {
          vx: (Math.random() - 0.5) * 0.15,
          vy: (Math.random() - 0.5) * 0.15,
          rotSpeed: (Math.random() - 0.5) * 3,
          wobblePhase: Math.random() * Math.PI * 2,
          wobbleSpeed: 1 + Math.random() * 2,
          alive: true,
          scale: scale,
          glow: 0,
        };
        scene.add(heart);
        hearts.push(heart);
      }

      // Initial hearts
      for (let i = 0; i < 12; i++) spawnHeart();

      // === CATCH PARTICLES ===
      function spawnCatchParticles(pos, color) {
        for (let i = 0; i < 15; i++) {
          const geo = new THREE.SphereGeometry(0.08 + Math.random() * 0.12, 6, 6);
          const isHeart = Math.random() > 0.5;
          const mat = new THREE.MeshBasicMaterial({
            color: isHeart ? color : 0xFFFFFF,
            transparent: true, opacity: 1,
          });
          const p = new THREE.Mesh(isHeart ? heartGeo : geo, mat);
          if (isHeart) p.scale.set(0.15, 0.15, 0.15);
          p.position.copy(pos);
          p.userData = {
            vx: (Math.random()-0.5) * 0.8,
            vy: Math.random() * 0.6 + 0.2,
            vz: (Math.random()-0.5) * 0.4,
            life: 1.0,
            decay: 0.015 + Math.random() * 0.015,
            rotV: (Math.random()-0.5) * 0.3,
          };
          scene.add(p);
          particles.push(p);
        }
      }

      // Score popup
      function showScorePopup(points, x, y) {
        const el = document.createElement('div');
        el.textContent = `+${points}`;
        el.style.cssText = `position:fixed;left:${x}px;top:${y}px;color:#FF6B8A;font-family:Nunito,sans-serif;font-weight:900;font-size:${18 + points * 2}px;pointer-events:none;z-index:20;text-shadow:0 0 10px rgba(255,107,138,0.5);transition:all 1s ease-out;`;
        document.body.appendChild(el);
        requestAnimationFrame(() => {
          el.style.transform = 'translateY(-60px) scale(1.5)';
          el.style.opacity = '0';
        });
        setTimeout(() => el.remove(), 1000);
      }

      // === CLICK TO LAUNCH FOX ===
      const raycaster = new THREE.Raycaster();
      const mouse = new THREE.Vector2();
      let mouseX = 0, mouseY = 0;
      let clickX = 0, clickY = 0;

      document.addEventListener('mousemove', (e) => {
        mouseX = (e.clientX / innerWidth - 0.5) * 2;
        mouseY = (e.clientY / innerHeight - 0.5) * 2;
      });

      container.addEventListener('click', (e) => {
        mouse.x = (e.clientX / innerWidth) * 2 - 1;
        mouse.y = -(e.clientY / innerHeight) * 2 + 1;
        clickX = e.clientX;
        clickY = e.clientY;

        // Convert click to world position
        raycaster.setFromCamera(mouse, camera);
        const plane = new THREE.Plane(new THREE.Vector3(0, 0, 1), 0);
        const target = new THREE.Vector3();
        raycaster.ray.intersectPlane(plane, target);

        if (target) {
          foxTargetX = target.x;
          foxTargetY = target.y;
          isChasing = true;

          // Find nearest heart
          let nearestDist = Infinity;
          chasedHeart = null;
          hearts.forEach(h => {
            if (!h.userData.alive) return;
            const dx = h.position.x - target.x;
            const dy = h.position.y - target.y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            if (dist < nearestDist && dist < 15) {
              nearestDist = dist;
              chasedHeart = h;
            }
          });

          // Open mouth when lunging
          mouthOpen = 1;
        }

        // Hide hint after first click
        if (hintEl.style.opacity !== '0') {
          hintEl.style.opacity = '0';
        }
      });

      // Touch support
      container.addEventListener('touchstart', (e) => {
        const t = e.touches[0];
        container.dispatchEvent(new MouseEvent('click', { clientX: t.clientX, clientY: t.clientY }));
      });

      // Nebulae — bigger, more vibrant
      for (let i = 0; i < 8; i++) {
        const colors = [0xFF6B8A, 0xB76CFD, 0xFF9A5C, 0x6366F1];
        const neb = new THREE.Mesh(
          new THREE.SphereGeometry(10 + Math.random() * 20, 16, 16),
          new THREE.MeshBasicMaterial({
            color: colors[i % 4], transparent: true,
            opacity: 0.04 + Math.random() * 0.04,
          })
        );
        neb.position.set((Math.random()-0.5)*100, (Math.random()-0.5)*60, -30 - Math.random()*40);
        scene.add(neb);
      }

      // Lighting
      scene.add(new THREE.AmbientLight(0x8B7BAB, 0.7));
      const key = new THREE.DirectionalLight(0xFFD4E5, 1.2);
      key.position.set(5, 5, 10);
      scene.add(key);
      const rim = new THREE.PointLight(0xB76CFD, 1.0, 40);
      rim.position.set(-8, 4, -5);
      scene.add(rim);
      const foxLight = new THREE.PointLight(0xFF9A5C, 0.5, 15);
      foxLight.position.set(0, 0, 5);
      foxGroup.add(foxLight);

      // Resize
      window.addEventListener('resize', () => {
        camera.aspect = innerWidth / innerHeight;
        camera.updateProjectionMatrix();
        renderer.setSize(innerWidth, innerHeight);
      });

      // === ANIMATE ===
      const clock = new THREE.Clock();
      let spawnTimer = 0;

      function animate() {
        requestAnimationFrame(animate);
        const t = clock.getElapsedTime();
        const dt = clock.getDelta() || 0.016;
        starMat.uniforms.uTime.value = t;

        // Fox physics — chase click target or nearest heart
        let tx = foxTargetX, ty = foxTargetY;
        if (chasedHeart && chasedHeart.userData.alive) {
          tx = chasedHeart.position.x;
          ty = chasedHeart.position.y;
        }

        if (isChasing) {
          const dx = tx - foxGroup.position.x;
          const dy = ty - foxGroup.position.y;
          const dist = Math.sqrt(dx*dx + dy*dy);

          foxVx += dx * 0.06;
          foxVy += dy * 0.06;
          foxVx *= 0.92;
          foxVy *= 0.92;

          // Lean into movement
          foxSpin += (Math.atan2(foxVx, 1) * 0.5 - foxSpin) * 0.1;

          if (dist < 1.5) {
            isChasing = false;
            foxVx *= 0.5;
            foxVy *= 0.5;
          }
        } else {
          // Gentle idle float
          foxVx *= 0.96;
          foxVy *= 0.96;
          foxVx += Math.sin(t * 0.3) * 0.005;
          foxVy += Math.cos(t * 0.4) * 0.005;
          foxSpin *= 0.95;
        }

        foxGroup.position.x += foxVx;
        foxGroup.position.y += foxVy;

        // Bob
        foxGroup.position.y += Math.sin(t * 1.2) * 0.02;

        // Fox rotation — look at mouse + movement tilt
        foxBody.rotation.y = mouseX * 0.2 + foxSpin;
        foxBody.rotation.x = -mouseY * 0.1;
        foxBody.rotation.z = -foxSpin * 0.5 + Math.sin(t * 0.7) * 0.03;

        // Squash & stretch from speed
        const speed = Math.sqrt(foxVx*foxVx + foxVy*foxVy);
        const targetSquash = 1 + speed * 0.15;
        foxSquash += (targetSquash - foxSquash) * 0.15;
        foxBody.scale.set(1/foxSquash, foxSquash, 1);

        // Ears — perk up when chasing, wiggle always
        const earPerk = isChasing ? 0.15 : 0;
        le.rotation.z = 0.3 - earPerk + Math.sin(t * 4) * 0.1;
        re.rotation.z = -0.3 + earPerk + Math.sin(t * 4 + 1) * 0.1;
        lei.rotation.z = le.rotation.z;
        rei.rotation.z = re.rotation.z;

        // Pupils track nearest heart or mouse
        let lookX = mouseX * 0.1;
        let lookY = -mouseY * 0.05;
        if (chasedHeart && chasedHeart.userData.alive) {
          const hd = chasedHeart.position.clone().sub(foxGroup.position).normalize();
          lookX = hd.x * 0.15;
          lookY = hd.y * 0.1;
        }
        leftPupil.position.x = -0.9 + lookX;
        leftPupil.position.y = 0.4 + lookY;
        rightPupil.position.x = 0.9 + lookX;
        rightPupil.position.y = 0.4 + lookY;

        // Mouth animation
        mouthOpen *= 0.92;
        mouth.scale.y = mouthOpen * 1.2;
        tongue.scale.y = mouthOpen > 0.3 ? mouthOpen : 0;

        // Blush intensifies with combo
        const blushIntensity = Math.min(0.35 + combo * 0.08, 0.8);
        lb.material.opacity = blushIntensity;
        rb.material.opacity = blushIntensity;

        // Hearts movement + collision
        hearts.forEach((h, idx) => {
          if (!h.userData.alive) return;
          const d = h.userData;
          h.position.x += d.vx;
          h.position.y += d.vy + Math.sin(t * d.wobbleSpeed + d.wobblePhase) * 0.02;
          h.rotation.y += d.rotSpeed * 0.01;
          h.rotation.z = Math.sin(t * d.wobbleSpeed + d.wobblePhase) * 0.3;

          // Pulse glow
          d.glow = Math.sin(t * 2 + idx) * 0.5 + 0.5;
          h.material.emissiveIntensity = 0.1 + d.glow * 0.15;

          // Bounce off edges
          if (h.position.x > 25 || h.position.x < -25) d.vx *= -1;
          if (h.position.y > 15 || h.position.y < -15) d.vy *= -1;

          // Fox collision
          const fx = foxGroup.position.x - h.position.x;
          const fy = foxGroup.position.y - h.position.y;
          const fdist = Math.sqrt(fx*fx + fy*fy);

          if (fdist < 2.5 + d.scale * 0.5) {
            // CAUGHT!
            d.alive = false;
            h.visible = false;

            const now = t;
            if (now - lastCatchTime < 2) combo++;
            else combo = 1;
            lastCatchTime = now;

            const points = combo;
            score += points;

            // Score UI
            scoreEl.textContent = `Score: ${score}  ${combo > 1 ? `(${combo}x combo!)` : ''}`;
            scoreEl.style.color = 'rgba(255,255,255,0.9)';

            // Screen popup
            const screenPos = h.position.clone().project(camera);
            const sx = (screenPos.x * 0.5 + 0.5) * innerWidth;
            const sy = (-screenPos.y * 0.5 + 0.5) * innerHeight;
            showScorePopup(points, sx, sy);

            // Particles
            spawnCatchParticles(h.position.clone(), h.material.color.getHex());

            // Fox reaction — happy bounce + mouth open
            mouthOpen = 1;
            foxSquash = 0.7;

            // Remove and respawn
            setTimeout(() => {
              scene.remove(h);
              const i = hearts.indexOf(h);
              if (i > -1) hearts.splice(i, 1);
            }, 100);
          }
        });

        // Spawn new hearts
        spawnTimer += dt;
        if (spawnTimer > 1.5 && hearts.filter(h => h.userData.alive).length < 10) {
          spawnHeart();
          spawnTimer = 0;
        }

        // Particles update
        for (let i = particles.length - 1; i >= 0; i--) {
          const p = particles[i];
          const pd = p.userData;
          p.position.x += pd.vx;
          p.position.y += pd.vy;
          p.position.z += pd.vz;
          pd.vy -= 0.015; // gravity
          pd.life -= pd.decay;
          p.material.opacity = pd.life;
          p.rotation.z += pd.rotV;
          if (pd.life <= 0) {
            scene.remove(p);
            particles.splice(i, 1);
          }
        }

        // Camera
        camera.position.x += (mouseX * 3 - camera.position.x) * 0.02;
        camera.position.y += (-mouseY * 2 - camera.position.y) * 0.02;
        camera.lookAt(foxGroup.position.x * 0.3, foxGroup.position.y * 0.3, 0);

        renderer.render(scene, camera);
      }
      animate();
    }
  </script>
</Layout>
