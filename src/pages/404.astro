---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Lost in the Distance | Far Fox" description="This page doesn't exist, but you found a game! Help your fox catch hearts.">
  <canvas id="game" style="position:fixed;inset:0;z-index:0;cursor:crosshair;touch-action:none;"></canvas>

  <div class="fixed inset-x-0 bottom-0 z-10 flex flex-col items-center pb-8 sm:pb-12 pointer-events-none">
    <div class="pointer-events-auto text-center px-6">
      <a
        href="/"
        class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-fox-pink to-fox-purple text-white font-800 hover:shadow-xl hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5 text-sm sm:text-base"
      >
        Take Me Home
      </a>
    </div>
  </div>

  <script is:inline>
  (function() {
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');
    let W, H;

    function resize() {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    // Load fox image
    const foxImg = new Image();
    foxImg.src = '/fox-logo.png';
    let foxLoaded = false;
    foxImg.onload = () => { foxLoaded = true; };

    // Game state
    let score = 0;
    let combo = 0;
    let lastCatchTime = 0;
    let shakeAmount = 0;
    let flashAlpha = 0;
    let gameStarted = false;
    let titleAlpha = 1;

    // Fox
    const fox = {
      x: 0, y: 0,
      vx: 0, vy: 0,
      targetX: 0, targetY: 0,
      size: 80,
      chasing: false,
      rotation: 0,
      squash: 1,
      stretch: 1,
      bouncePhase: 0,
      trail: [],
    };

    // Hearts
    const hearts = [];
    const particles = [];
    const popups = [];
    const stars = [];
    const bgOrbs = [];

    // Stars
    for (let i = 0; i < 150; i++) {
      stars.push({
        x: Math.random(), y: Math.random(),
        size: Math.random() * 2.5 + 0.5,
        twinkleSpeed: 1 + Math.random() * 3,
        twinkleOffset: Math.random() * Math.PI * 2,
        color: Math.random() > 0.85 ? (Math.random() > 0.5 ? '#FF6B8A' : '#B76CFD') : '#fff',
      });
    }

    // Background gradient orbs
    for (let i = 0; i < 6; i++) {
      bgOrbs.push({
        x: Math.random(), y: Math.random(),
        radius: 150 + Math.random() * 250,
        color: ['#FF6B8A', '#B76CFD', '#FF9A5C', '#6366F1', '#F472B6', '#8B5CF6'][i],
        vx: (Math.random() - 0.5) * 0.0002,
        vy: (Math.random() - 0.5) * 0.0002,
        alpha: 0.08 + Math.random() * 0.06,
      });
    }

    function drawHeart(cx, cy, size, color, glow) {
      ctx.save();
      ctx.translate(cx, cy);
      ctx.beginPath();
      const s = size;
      ctx.moveTo(0, s * 0.3);
      ctx.bezierCurveTo(-s * 0.05, s * 0.1, -s * 0.5, -s * 0.1, -s * 0.5, -s * 0.3);
      ctx.bezierCurveTo(-s * 0.5, -s * 0.55, -s * 0.25, -s * 0.7, 0, -s * 0.5);
      ctx.bezierCurveTo(s * 0.25, -s * 0.7, s * 0.5, -s * 0.55, s * 0.5, -s * 0.3);
      ctx.bezierCurveTo(s * 0.5, -s * 0.1, s * 0.05, s * 0.1, 0, s * 0.3);
      ctx.closePath();

      if (glow > 0) {
        ctx.shadowColor = color;
        ctx.shadowBlur = 20 * glow;
      }

      // Gradient fill
      const grad = ctx.createRadialGradient(-s*0.1, -s*0.2, 0, 0, 0, s*0.6);
      grad.addColorStop(0, lightenColor(color, 40));
      grad.addColorStop(1, color);
      ctx.fillStyle = grad;
      ctx.fill();

      // Shine
      ctx.beginPath();
      ctx.ellipse(-s * 0.18, -s * 0.32, s * 0.1, s * 0.06, -0.5, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(255,255,255,0.6)';
      ctx.fill();

      ctx.restore();
    }

    function lightenColor(hex, amount) {
      let r = parseInt(hex.slice(1,3), 16);
      let g = parseInt(hex.slice(3,5), 16);
      let b = parseInt(hex.slice(5,7), 16);
      r = Math.min(255, r + amount);
      g = Math.min(255, g + amount);
      b = Math.min(255, b + amount);
      return `rgb(${r},${g},${b})`;
    }

    function spawnHeart() {
      const colors = ['#FF6B8A', '#B76CFD', '#FF9A5C', '#FFB6C1', '#F472B6', '#E879F9'];
      const side = Math.floor(Math.random() * 4);
      let x, y;
      if (side === 0) { x = -40; y = Math.random() * H; }
      else if (side === 1) { x = W + 40; y = Math.random() * H; }
      else if (side === 2) { x = Math.random() * W; y = -40; }
      else { x = Math.random() * W; y = H + 40; }

      hearts.push({
        x, y,
        vx: (Math.random() - 0.5) * 1.5,
        vy: (Math.random() - 0.5) * 1.5,
        size: 25 + Math.random() * 20,
        color: colors[Math.floor(Math.random() * colors.length)],
        rotation: Math.random() * Math.PI * 2,
        rotSpeed: (Math.random() - 0.5) * 0.04,
        wobblePhase: Math.random() * Math.PI * 2,
        wobbleSpeed: 1 + Math.random() * 2,
        pulsePhase: Math.random() * Math.PI * 2,
        alive: true,
      });
    }

    // Initial hearts
    for (let i = 0; i < 8; i++) {
      const h = {
        x: W * 0.15 + Math.random() * W * 0.7,
        y: H * 0.15 + Math.random() * H * 0.6,
        vx: (Math.random() - 0.5) * 1.5,
        vy: (Math.random() - 0.5) * 1.5,
        size: 25 + Math.random() * 20,
        color: ['#FF6B8A', '#B76CFD', '#FF9A5C', '#FFB6C1', '#F472B6', '#E879F9'][i % 6],
        rotation: Math.random() * Math.PI * 2,
        rotSpeed: (Math.random() - 0.5) * 0.04,
        wobblePhase: Math.random() * Math.PI * 2,
        wobbleSpeed: 1 + Math.random() * 2,
        pulsePhase: Math.random() * Math.PI * 2,
        alive: true,
      };
      hearts.push(h);
    }

    // Center fox
    fox.x = W / 2;
    fox.y = H / 2;

    function spawnCatchParticles(x, y, color) {
      for (let i = 0; i < 20; i++) {
        const angle = (Math.PI * 2 / 20) * i + Math.random() * 0.3;
        const speed = 2 + Math.random() * 6;
        const isHeart = Math.random() > 0.6;
        particles.push({
          x, y,
          vx: Math.cos(angle) * speed,
          vy: Math.sin(angle) * speed,
          life: 1,
          decay: 0.015 + Math.random() * 0.02,
          size: isHeart ? 12 + Math.random() * 8 : 3 + Math.random() * 5,
          color: Math.random() > 0.3 ? color : '#FFD700',
          isHeart,
          rotation: Math.random() * Math.PI * 2,
          rotSpeed: (Math.random() - 0.5) * 0.2,
          gravity: 0.08 + Math.random() * 0.05,
        });
      }

      // Ring burst
      particles.push({
        x, y, vx: 0, vy: 0,
        life: 1, decay: 0.03,
        size: 5, maxSize: 80,
        color, isRing: true, gravity: 0,
      });
    }

    function spawnPopup(x, y, points) {
      popups.push({
        x, y,
        text: combo > 1 ? `+${points} x${combo}!` : `+${points}`,
        life: 1,
        vy: -2,
        size: 20 + Math.min(points, 5) * 4,
        color: combo > 3 ? '#FFD700' : combo > 1 ? '#FF6B8A' : '#fff',
      });
    }

    // Input
    function handleInput(px, py) {
      fox.targetX = px;
      fox.targetY = py;
      fox.chasing = true;
      if (!gameStarted) {
        gameStarted = true;
      }
    }

    canvas.addEventListener('click', (e) => handleInput(e.clientX, e.clientY));
    canvas.addEventListener('touchstart', (e) => {
      e.preventDefault();
      handleInput(e.touches[0].clientX, e.touches[0].clientY);
    });

    let mouseX = W/2, mouseY = H/2;
    canvas.addEventListener('mousemove', (e) => { mouseX = e.clientX; mouseY = e.clientY; });

    // Main loop
    let time = 0;
    let spawnTimer = 0;
    let lastFrame = performance.now();

    function loop(now) {
      requestAnimationFrame(loop);
      const rawDt = (now - lastFrame) / 1000;
      const dt = Math.min(rawDt, 0.05);
      lastFrame = now;
      time += dt;
      spawnTimer += dt;

      ctx.clearRect(0, 0, W, H);

      // Background
      const bgGrad = ctx.createLinearGradient(0, 0, 0, H);
      bgGrad.addColorStop(0, '#0f0a2e');
      bgGrad.addColorStop(0.5, '#1a1145');
      bgGrad.addColorStop(1, '#12082a');
      ctx.fillStyle = bgGrad;
      ctx.fillRect(0, 0, W, H);

      // Animated gradient orbs
      bgOrbs.forEach(orb => {
        orb.x += orb.vx;
        orb.y += orb.vy;
        if (orb.x < -0.2 || orb.x > 1.2) orb.vx *= -1;
        if (orb.y < -0.2 || orb.y > 1.2) orb.vy *= -1;
        const grad = ctx.createRadialGradient(orb.x * W, orb.y * H, 0, orb.x * W, orb.y * H, orb.radius);
        grad.addColorStop(0, orb.color + Math.round(orb.alpha * 255).toString(16).padStart(2,'0'));
        grad.addColorStop(1, orb.color + '00');
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, W, H);
      });

      // Stars
      stars.forEach(s => {
        const alpha = 0.3 + 0.7 * ((Math.sin(time * s.twinkleSpeed + s.twinkleOffset) + 1) / 2);
        ctx.globalAlpha = alpha;
        ctx.fillStyle = s.color;
        ctx.beginPath();
        ctx.arc(s.x * W, s.y * H, s.size, 0, Math.PI * 2);
        ctx.fill();
      });
      ctx.globalAlpha = 1;

      // Screen shake
      if (shakeAmount > 0.5) {
        ctx.save();
        ctx.translate(
          (Math.random() - 0.5) * shakeAmount,
          (Math.random() - 0.5) * shakeAmount
        );
        shakeAmount *= 0.9;
      }

      // Hearts
      hearts.forEach((h, i) => {
        if (!h.alive) return;

        h.x += h.vx;
        h.y += h.vy + Math.sin(time * h.wobbleSpeed + h.wobblePhase) * 0.5;
        h.rotation += h.rotSpeed;

        // Bounce off edges with padding
        if (h.x < 30) { h.x = 30; h.vx = Math.abs(h.vx); }
        if (h.x > W - 30) { h.x = W - 30; h.vx = -Math.abs(h.vx); }
        if (h.y < 30) { h.y = 30; h.vy = Math.abs(h.vy); }
        if (h.y > H - 100) { h.y = H - 100; h.vy = -Math.abs(h.vy); }

        const pulse = 1 + Math.sin(time * 3 + h.pulsePhase) * 0.1;
        const glow = (Math.sin(time * 2 + i) + 1) / 2;

        ctx.save();
        ctx.translate(h.x, h.y);
        ctx.rotate(h.rotation);
        ctx.scale(pulse, pulse);
        drawHeart(0, 0, h.size, h.color, 0.3 + glow * 0.4);
        ctx.restore();

        // Collision with fox
        const dx = fox.x - h.x;
        const dy = fox.y - h.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        const catchRadius = fox.size * 0.4 + h.size * 0.4;

        if (dist < catchRadius) {
          h.alive = false;
          const now = time;
          if (now - lastCatchTime < 2.5) combo++;
          else combo = 1;
          lastCatchTime = now;

          const points = combo;
          score += points;

          spawnCatchParticles(h.x, h.y, h.color);
          spawnPopup(h.x, h.y - 30, points);

          // Fox reaction
          fox.squash = 0.6;
          fox.stretch = 1.4;
          shakeAmount = 5 + combo * 2;
          flashAlpha = 0.15;
        }
      });

      // Remove dead hearts
      for (let i = hearts.length - 1; i >= 0; i--) {
        if (!hearts[i].alive) hearts.splice(i, 1);
      }

      // Spawn hearts
      if (spawnTimer > 1.8 && hearts.length < 10) {
        spawnHeart();
        spawnTimer = 0;
      }

      // Fox physics
      if (fox.chasing) {
        const dx = fox.targetX - fox.x;
        const dy = fox.targetY - fox.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        // Also gravitate toward nearest heart
        let nearestHeart = null;
        let nearestDist = Infinity;
        hearts.forEach(h => {
          if (!h.alive) return;
          const hdx = h.x - fox.targetX;
          const hdy = h.y - fox.targetY;
          const d = Math.sqrt(hdx*hdx + hdy*hdy);
          if (d < nearestDist && d < 200) {
            nearestDist = d;
            nearestHeart = h;
          }
        });

        let tx = fox.targetX, ty = fox.targetY;
        if (nearestHeart) {
          tx = nearestHeart.x;
          ty = nearestHeart.y;
        }

        const tdx = tx - fox.x;
        const tdy = ty - fox.y;
        const tdist = Math.sqrt(tdx * tdx + tdy * tdy);

        const accel = 0.4;
        fox.vx += (tdx / Math.max(tdist, 1)) * accel;
        fox.vy += (tdy / Math.max(tdist, 1)) * accel;
        fox.vx *= 0.94;
        fox.vy *= 0.94;

        if (dist < 10) {
          fox.chasing = false;
        }
      } else {
        fox.vx *= 0.97;
        fox.vy *= 0.97;
        // Idle float
        fox.vx += Math.sin(time * 0.5) * 0.03;
        fox.vy += Math.cos(time * 0.7) * 0.03;
      }

      fox.x += fox.vx;
      fox.y += fox.vy;

      // Keep fox in bounds
      fox.x = Math.max(40, Math.min(W - 40, fox.x));
      fox.y = Math.max(40, Math.min(H - 120, fox.y));

      fox.bouncePhase += dt * 3;

      // Fox trail
      fox.trail.push({ x: fox.x, y: fox.y, alpha: 0.4, size: fox.size * 0.6 });
      if (fox.trail.length > 12) fox.trail.shift();

      // Draw fox trail
      fox.trail.forEach((t, i) => {
        t.alpha *= 0.88;
        if (foxLoaded && t.alpha > 0.02) {
          ctx.globalAlpha = t.alpha * 0.3;
          const s = t.size * (i / fox.trail.length);
          ctx.drawImage(foxImg, t.x - s/2, t.y - s/2, s, s);
        }
      });
      ctx.globalAlpha = 1;

      // Draw fox
      const speed = Math.sqrt(fox.vx * fox.vx + fox.vy * fox.vy);
      const targetSquash = speed > 1 ? 0.85 : 1;
      const targetStretch = speed > 1 ? 1.15 : 1;
      fox.squash += (targetSquash - fox.squash) * 0.15;
      fox.stretch += (targetStretch - fox.stretch) * 0.15;

      // Rotation based on movement
      const targetRot = Math.atan2(fox.vy, fox.vx) * 0.15;
      fox.rotation += (targetRot - fox.rotation) * 0.1;

      const bobY = Math.sin(fox.bouncePhase) * 4;

      if (foxLoaded) {
        ctx.save();
        ctx.translate(fox.x, fox.y + bobY);
        ctx.rotate(fox.rotation);
        ctx.scale(fox.stretch, fox.squash);

        // Glow behind fox
        const foxGlow = ctx.createRadialGradient(0, 0, fox.size * 0.2, 0, 0, fox.size * 0.8);
        foxGlow.addColorStop(0, 'rgba(255,154,92,0.3)');
        foxGlow.addColorStop(1, 'rgba(255,154,92,0)');
        ctx.fillStyle = foxGlow;
        ctx.beginPath();
        ctx.arc(0, 0, fox.size * 0.8, 0, Math.PI * 2);
        ctx.fill();

        const s = fox.size;
        ctx.drawImage(foxImg, -s/2, -s/2, s, s);
        ctx.restore();
      }

      // Particles
      for (let i = particles.length - 1; i >= 0; i--) {
        const p = particles[i];
        p.life -= p.decay;

        if (p.isRing) {
          p.size += (p.maxSize - p.size) * 0.1;
          ctx.globalAlpha = p.life * 0.5;
          ctx.strokeStyle = p.color;
          ctx.lineWidth = 2;
          ctx.beginPath();
          ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
          ctx.stroke();
        } else {
          p.x += p.vx;
          p.y += p.vy;
          p.vy += p.gravity;
          p.vx *= 0.98;
          p.rotation += p.rotSpeed;

          ctx.globalAlpha = p.life;
          if (p.isHeart) {
            ctx.save();
            ctx.translate(p.x, p.y);
            ctx.rotate(p.rotation);
            ctx.scale(p.life, p.life);
            drawHeart(0, 0, p.size, p.color, 0);
            ctx.restore();
          } else {
            // Sparkle
            ctx.fillStyle = p.color;
            ctx.beginPath();
            ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        ctx.globalAlpha = 1;
        if (p.life <= 0) particles.splice(i, 1);
      }

      // Popups
      for (let i = popups.length - 1; i >= 0; i--) {
        const p = popups[i];
        p.life -= 0.015;
        p.y += p.vy;
        p.vy *= 0.98;

        ctx.globalAlpha = p.life;
        ctx.fillStyle = p.color;
        ctx.font = `900 ${p.size * (1 + (1-p.life)*0.5)}px Nunito, sans-serif`;
        ctx.textAlign = 'center';
        ctx.shadowColor = p.color;
        ctx.shadowBlur = 10;
        ctx.fillText(p.text, p.x, p.y);
        ctx.shadowBlur = 0;
        ctx.globalAlpha = 1;

        if (p.life <= 0) popups.splice(i, 1);
      }

      if (shakeAmount > 0.5) ctx.restore();

      // Flash effect
      if (flashAlpha > 0.01) {
        ctx.globalAlpha = flashAlpha;
        ctx.fillStyle = '#fff';
        ctx.fillRect(0, 0, W, H);
        ctx.globalAlpha = 1;
        flashAlpha *= 0.85;
      }

      // 404 Title — always visible, large, centered top area
      const centerY = Math.min(H * 0.28, 220);

      // Title glow
      ctx.save();
      ctx.textAlign = 'center';

      // "404" big
      ctx.font = '900 clamp(80px, 15vw, 160px) Nunito, sans-serif';
      // Use font size based on screen
      const fontSize404 = Math.min(Math.max(W * 0.15, 80), 160);
      ctx.font = `900 ${fontSize404}px Nunito, sans-serif`;

      // Gradient text
      const textGrad = ctx.createLinearGradient(W/2 - 150, centerY, W/2 + 150, centerY);
      textGrad.addColorStop(0, '#FF6B8A');
      textGrad.addColorStop(0.5, '#B76CFD');
      textGrad.addColorStop(1, '#FF9A5C');
      ctx.fillStyle = textGrad;
      ctx.shadowColor = '#FF6B8A';
      ctx.shadowBlur = 30;
      ctx.fillText('404', W/2, centerY);
      ctx.shadowBlur = 0;

      // Subtitle
      const subSize = Math.min(Math.max(W * 0.025, 16), 28);
      ctx.font = `800 ${subSize}px Nunito, sans-serif`;
      ctx.fillStyle = 'rgba(255,255,255,0.85)';
      ctx.shadowColor = 'rgba(0,0,0,0.5)';
      ctx.shadowBlur = 8;
      ctx.fillText('Lost in the distance', W/2, centerY + fontSize404 * 0.35);
      ctx.shadowBlur = 0;

      // Hint text (fades after interaction)
      if (!gameStarted) {
        const hintAlpha = 0.4 + Math.sin(time * 2) * 0.2;
        ctx.globalAlpha = hintAlpha;
        ctx.font = `700 ${Math.max(14, subSize * 0.7)}px Nunito, sans-serif`;
        ctx.fillStyle = 'rgba(255,255,255,0.7)';
        ctx.fillText('click anywhere to help your fox catch hearts', W/2, centerY + fontSize404 * 0.55);
        ctx.globalAlpha = 1;
      }

      // Score (top right)
      if (score > 0) {
        const scoreSize = Math.min(Math.max(W * 0.02, 16), 24);
        ctx.font = `800 ${scoreSize}px Nunito, sans-serif`;
        ctx.textAlign = 'right';
        ctx.fillStyle = 'rgba(255,255,255,0.9)';
        ctx.shadowColor = '#FF6B8A';
        ctx.shadowBlur = 10;
        const scoreText = combo > 1 ? `${score} pts  ·  ${combo}x combo` : `${score} pts`;
        ctx.fillText(scoreText, W - 24, 40);
        ctx.shadowBlur = 0;
      }

      ctx.restore();
    }

    requestAnimationFrame(loop);
  })();
  </script>
</Layout>
