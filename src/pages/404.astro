---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Lost in the Distance | Far Fox" description="This page doesn't exist — but you found something beautiful.">
  <!-- Atmospheric canvas background -->
  <canvas id="bg" style="position:fixed;inset:0;z-index:0;"></canvas>

  <!-- Fox layer — positioned via JS, above canvas, below text -->
  <div id="fox-wrap" style="position:fixed;z-index:1;pointer-events:none;will-change:transform;">
    <div id="fox-glow" style="position:absolute;inset:-60%;border-radius:50%;background:radial-gradient(circle,rgba(255,154,92,0.18) 0%,rgba(255,107,138,0.06) 40%,rgba(183,108,253,0.02) 65%,transparent 100%);"></div>
    <img id="fox" src="/fox-logo.png" alt="" style="position:relative;width:100%;height:100%;z-index:1;" />
  </div>

  <!-- HTML UI — crisp text rendering -->
  <div style="position:fixed;inset:0;z-index:2;pointer-events:none;display:flex;flex-direction:column;align-items:center;justify-content:center;">
    <div style="text-align:center;padding:0 24px;margin-top:-12vh;">
      <h1 class="select-none" style="font-family:Nunito,sans-serif;font-weight:900;font-size:clamp(100px,20vw,240px);line-height:0.85;background:linear-gradient(135deg,#FF6B8A 0%,#E879F9 30%,#B76CFD 60%,#FF9A5C 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 60px rgba(183,108,253,0.3)) drop-shadow(0 0 120px rgba(255,107,138,0.15));margin:0;letter-spacing:-0.02em;">
        404
      </h1>
      <p class="select-none" style="font-family:Nunito,sans-serif;font-weight:600;font-size:clamp(14px,2.2vw,24px);color:rgba(255,255,255,0.6);margin:clamp(8px,1.5vw,20px) 0 0;letter-spacing:0.02em;">
        Looks like you've wandered too far, little fox
      </p>
    </div>
  </div>

  <!-- Bottom CTA -->
  <div class="fixed inset-x-0 bottom-0 z-10 flex flex-col items-center pb-8 sm:pb-12 pointer-events-none">
    <div class="pointer-events-auto text-center px-6">
      <a
        href="/"
        class="inline-block px-8 py-3 rounded-full bg-gradient-to-r from-fox-pink to-fox-purple text-white font-800 hover:shadow-xl hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5 text-sm sm:text-base"
        style="backdrop-filter:blur(12px);background:linear-gradient(135deg,rgba(255,107,138,0.85),rgba(183,108,253,0.85));border:1px solid rgba(255,255,255,0.1);"
      >
        Take Me Home
      </a>
    </div>
  </div>

  <!-- Interaction layer — captures mouse/touch above everything -->
  <div id="interact" style="position:fixed;inset:0;z-index:5;cursor:none;touch-action:none;"></div>

  <!-- Custom cursor -->
  <div id="cursor" style="position:fixed;z-index:6;pointer-events:none;width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.7);box-shadow:0 0 12px rgba(255,107,138,0.5),0 0 30px rgba(183,108,253,0.2);transform:translate(-50%,-50%);opacity:0;transition:opacity 0.3s;will-change:transform;"></div>

  <script is:inline>
  (function() {
    const canvas = document.getElementById('bg');
    const ctx = canvas.getContext('2d');
    const foxWrap = document.getElementById('fox-wrap');
    const foxGlow = document.getElementById('fox-glow');
    const cursorEl = document.getElementById('cursor');
    const interact = document.getElementById('interact');
    let W, H, dpr;

    const foxSize = Math.min(90, Math.max(56, window.innerWidth * 0.08));
    foxWrap.style.width = foxSize + 'px';
    foxWrap.style.height = foxSize + 'px';

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = window.innerWidth;
      H = window.innerHeight;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }
    resize();
    window.addEventListener('resize', resize);

    function lerp(a, b, t) { return a + (b - a) * t; }

    // ---- BACKGROUND OBJECTS ----

    // Stars — 3 depth layers
    const stars = [];
    for (let i = 0; i < 200; i++) {
      const depth = i < 100 ? 0 : i < 160 ? 1 : 2;
      const brand = Math.random() > 0.92;
      stars.push({
        x: Math.random(), y: Math.random(),
        size: (depth * 0.4 + 0.3) + Math.random() * (depth * 0.3 + 0.3),
        phase: Math.random() * Math.PI * 2,
        speed: 0.6 + Math.random() * 2,
        depth,
        color: brand ? (Math.random() > 0.5 ? '#FF6B8A' : '#B76CFD') : '#fff',
        baseAlpha: brand ? 0.6 : 0.15 + depth * 0.15,
      });
    }
    const depthParallax = [0.006, 0.018, 0.04];

    // Nebulae
    const nebulae = [
      { x: 0.18, y: 0.28, r: 280, c: [255,107,138], a: 0.04, p: 0.025 },
      { x: 0.78, y: 0.22, r: 220, c: [183,108,253], a: 0.035, p: 0.02 },
      { x: 0.5, y: 0.72, r: 300, c: [255,154,92], a: 0.03, p: 0.03 },
      { x: 0.88, y: 0.62, r: 200, c: [139,92,246], a: 0.025, p: 0.018 },
      { x: 0.12, y: 0.78, r: 240, c: [244,114,182], a: 0.03, p: 0.022 },
    ];

    // Sparkle trail particles (from fox movement)
    const sparkles = [];

    // Ambient floating light motes
    const motes = [];
    for (let i = 0; i < 25; i++) {
      motes.push({
        x: Math.random() * W, y: Math.random() * H,
        size: 1 + Math.random() * 2,
        speedX: (Math.random() - 0.5) * 0.3,
        speedY: -0.1 - Math.random() * 0.2,
        phase: Math.random() * Math.PI * 2,
        color: ['rgba(255,107,138,','rgba(183,108,253,','rgba(255,154,92,','rgba(255,255,255,'][Math.floor(Math.random() * 4)],
      });
    }

    // Shooting stars
    const shoots = [];
    function maybeShoot() {
      if (Math.random() > 0.002 || shoots.length > 1) return;
      shoots.push({
        x: Math.random() * W * 0.6, y: -10,
        angle: 0.4 + Math.random() * 0.3,
        speed: 10 + Math.random() * 8,
        life: 1, len: 80 + Math.random() * 60,
      });
    }

    // ---- FOX STATE ----
    const fox = { x: W / 2, y: H * 0.58, vx: 0, vy: 0 };
    let mouseActive = false;
    let mx = W / 2, my = H / 2;
    let targetX = W / 2, targetY = H * 0.58;

    interact.addEventListener('mousemove', e => {
      mx = e.clientX; my = e.clientY;
      cursorEl.style.opacity = '1';
      cursorEl.style.left = mx + 'px';
      cursorEl.style.top = my + 'px';
      mouseActive = true;
    });
    interact.addEventListener('mouseleave', () => { cursorEl.style.opacity = '0'; });
    interact.addEventListener('click', e => {
      targetX = e.clientX; targetY = e.clientY;
      mouseActive = true;
      // Click ripple
      sparkles.push(
        ...Array.from({ length: 6 }, (_, i) => {
          const a = (Math.PI * 2 / 6) * i;
          return { x: e.clientX, y: e.clientY, vx: Math.cos(a) * 1.5, vy: Math.sin(a) * 1.5, life: 1, size: 2.5, color: 'rgba(255,255,255,' };
        })
      );
    });
    interact.addEventListener('touchstart', e => {
      e.preventDefault();
      const t = e.touches[0];
      mx = t.clientX; my = t.clientY;
      targetX = mx; targetY = my;
      mouseActive = true;
    }, { passive: false });
    interact.addEventListener('touchmove', e => {
      e.preventDefault();
      mx = e.touches[0].clientX; my = e.touches[0].clientY;
    }, { passive: false });

    // ---- RENDER LOOP ----
    let t = 0, last = performance.now();

    function frame(now) {
      requestAnimationFrame(frame);
      const dt = Math.min((now - last) / 1000, 0.05);
      last = now;
      t += dt;

      ctx.clearRect(0, 0, W, H);

      // Sky
      const sky = ctx.createLinearGradient(0, 0, W * 0.2, H);
      sky.addColorStop(0, '#04020a');
      sky.addColorStop(0.35, '#0a0618');
      sky.addColorStop(0.65, '#110c2a');
      sky.addColorStop(1, '#06031a');
      ctx.fillStyle = sky;
      ctx.fillRect(0, 0, W, H);

      // Slow breathing color wash
      const washX = W * 0.5 + Math.sin(t * 0.07) * W * 0.2;
      const washY = H * 0.4 + Math.cos(t * 0.05) * H * 0.15;
      const wash = ctx.createRadialGradient(washX, washY, 0, W * 0.5, H * 0.5, W * 0.8);
      wash.addColorStop(0, `rgba(183,108,253,${0.02 + Math.sin(t * 0.1) * 0.008})`);
      wash.addColorStop(0.5, `rgba(255,107,138,${0.01 + Math.cos(t * 0.08) * 0.005})`);
      wash.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = wash;
      ctx.fillRect(0, 0, W, H);

      const px = (mx / W - 0.5) * 2;
      const py = (my / H - 0.5) * 2;

      // Nebulae
      nebulae.forEach(n => {
        const nx = n.x * W + px * n.p * W;
        const ny = n.y * H + py * n.p * H;
        const pulse = 1 + Math.sin(t * 0.25 + n.x * 4) * 0.1;
        const g = ctx.createRadialGradient(nx, ny, 0, nx, ny, n.r * pulse);
        g.addColorStop(0, `rgba(${n.c[0]},${n.c[1]},${n.c[2]},${n.a})`);
        g.addColorStop(0.5, `rgba(${n.c[0]},${n.c[1]},${n.c[2]},${n.a * 0.25})`);
        g.addColorStop(1, `rgba(${n.c[0]},${n.c[1]},${n.c[2]},0)`);
        ctx.fillStyle = g;
        ctx.fillRect(0, 0, W, H);
      });

      // Stars
      stars.forEach(s => {
        const pf = depthParallax[s.depth];
        const sx = ((s.x * W + px * pf * W) % W + W) % W;
        const sy = ((s.y * H + py * pf * H) % H + H) % H;
        const tw = s.baseAlpha * (0.4 + 0.6 * (Math.sin(t * s.speed + s.phase) * 0.5 + 0.5));
        ctx.globalAlpha = tw;
        ctx.fillStyle = s.color;
        ctx.beginPath();
        ctx.arc(sx, sy, s.size, 0, Math.PI * 2);
        ctx.fill();
        if (s.size > 1.4 && tw > 0.35) {
          ctx.globalAlpha = (tw - 0.35) * 0.4;
          ctx.fillRect(sx - s.size * 2.5, sy - 0.25, s.size * 5, 0.5);
          ctx.fillRect(sx - 0.25, sy - s.size * 2.5, 0.5, s.size * 5);
        }
      });
      ctx.globalAlpha = 1;

      // Shooting stars
      maybeShoot();
      for (let i = shoots.length - 1; i >= 0; i--) {
        const s = shoots[i];
        s.x += Math.cos(s.angle) * s.speed;
        s.y += Math.sin(s.angle) * s.speed;
        s.life -= dt * 1.5;
        if (s.life <= 0 || s.x > W + 60 || s.y > H + 60) { shoots.splice(i, 1); continue; }
        const dx = Math.cos(s.angle), dy = Math.sin(s.angle);
        const g = ctx.createLinearGradient(s.x - dx * s.len * s.life, s.y - dy * s.len * s.life, s.x, s.y);
        g.addColorStop(0, 'rgba(255,255,255,0)');
        g.addColorStop(1, `rgba(255,255,255,${s.life * 0.8})`);
        ctx.strokeStyle = g;
        ctx.lineWidth = 1.5;
        ctx.lineCap = 'round';
        ctx.beginPath();
        ctx.moveTo(s.x - dx * s.len * s.life, s.y - dy * s.len * s.life);
        ctx.lineTo(s.x, s.y);
        ctx.stroke();
      }

      // Ambient motes
      motes.forEach(m => {
        m.x += m.speedX + Math.sin(t * 0.5 + m.phase) * 0.15;
        m.y += m.speedY;
        if (m.y < -10) { m.y = H + 10; m.x = Math.random() * W; }
        if (m.x < -10) m.x = W + 10;
        if (m.x > W + 10) m.x = -10;
        const a = 0.15 + 0.15 * Math.sin(t * 1.5 + m.phase);
        ctx.fillStyle = m.color + a + ')';
        ctx.beginPath();
        ctx.arc(m.x, m.y, m.size, 0, Math.PI * 2);
        ctx.fill();
      });

      // Sparkle trail particles
      for (let i = sparkles.length - 1; i >= 0; i--) {
        const p = sparkles[i];
        p.x += p.vx; p.y += p.vy;
        p.vx *= 0.96; p.vy *= 0.96;
        p.life -= dt * 2;
        if (p.life <= 0) { sparkles.splice(i, 1); continue; }
        ctx.globalAlpha = p.life * 0.7;
        ctx.fillStyle = p.color + '0.9)';
        ctx.shadowColor = p.color + '0.5)';
        ctx.shadowBlur = 8;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size * p.life, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }
      ctx.globalAlpha = 1;

      // Vignette
      const vig = ctx.createRadialGradient(W/2, H/2, W * 0.2, W/2, H/2, W * 0.9);
      vig.addColorStop(0, 'rgba(0,0,0,0)');
      vig.addColorStop(1, 'rgba(0,0,0,0.5)');
      ctx.fillStyle = vig;
      ctx.fillRect(0, 0, W, H);

      // ---- FOX MOVEMENT ----
      if (mouseActive) {
        const dx = targetX - fox.x, dy = targetY - fox.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 0.5) {
          const force = Math.min(dist * 0.03, 6);
          fox.vx += (dx / dist) * force;
          fox.vy += (dy / dist) * force;
        }
      }
      // Very gentle ambient drift
      fox.vx += Math.sin(t * 0.2) * 0.008;
      fox.vy += Math.cos(t * 0.28) * 0.008;

      fox.vx *= 0.88;
      fox.vy *= 0.88;
      fox.x += fox.vx;
      fox.y += fox.vy;

      // Soft bounds
      const pad = foxSize * 0.4;
      fox.x = Math.max(pad, Math.min(W - pad, fox.x));
      fox.y = Math.max(pad, Math.min(H - foxSize * 1.2, fox.y));

      // Emit sparkle trail when moving
      const spd = Math.sqrt(fox.vx * fox.vx + fox.vy * fox.vy);
      if (spd > 0.8 && Math.random() < spd * 0.15) {
        const colors = ['rgba(255,154,92,', 'rgba(255,107,138,', 'rgba(183,108,253,', 'rgba(255,255,255,'];
        sparkles.push({
          x: fox.x + (Math.random() - 0.5) * foxSize * 0.4,
          y: fox.y + (Math.random() - 0.5) * foxSize * 0.4,
          vx: (Math.random() - 0.5) * 0.5 - fox.vx * 0.1,
          vy: (Math.random() - 0.5) * 0.5 - fox.vy * 0.1,
          life: 0.6 + Math.random() * 0.4,
          size: 1.5 + Math.random() * 2,
          color: colors[Math.floor(Math.random() * colors.length)],
        });
      }

      // Position fox DOM element
      const tilt = Math.atan2(fox.vy, fox.vx) * 0.06;
      foxWrap.style.transform = `translate(${fox.x - foxSize / 2}px, ${fox.y - foxSize / 2}px) rotate(${tilt}rad)`;

      // Glow pulse
      const glowScale = 1 + Math.sin(t * 0.8) * 0.08;
      foxGlow.style.transform = `scale(${glowScale})`;
      foxGlow.style.opacity = 0.7 + Math.sin(t * 1.2) * 0.15;
    }

    requestAnimationFrame(frame);
  })();
  </script>
</Layout>
