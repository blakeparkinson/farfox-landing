---
import Layout from '../../layouts/Layout.astro';
import { fetchProfileBySlug } from '../../lib/supabase';
import {
  RITUAL_QUESTIONS,
  findChoice,
  ritualsTagline,
} from '../../lib/connectionRituals';

// SSR — the profile data needs to live in HTML for OG previews to
// resolve when this URL is shared on social. Static gen would be
// stale; we want live data per slug.
export const prerender = false;

const { slug } = Astro.params;

if (!slug || typeof slug !== 'string') {
  return Astro.redirect('/404');
}

// `?just_made=1` is set by the public quiz flow right after a fresh
// anonymous result is created — we use it to surface a louder
// "save & connect with your partner" upsell at the top of the page.
const isFreshResult = Astro.url.searchParams.get('just_made') === '1';

const profile = await fetchProfileBySlug(slug);

if (!profile || !profile.connection_rituals) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const firstName = profile.name.split(' ')[0];
const answers = profile.connection_rituals;
const tagline = ritualsTagline(answers);

// Build the answered list once for clean rendering below.
const answered = RITUAL_QUESTIONS.map((q) => {
  const choice = findChoice(q.key, answers[q.key] ?? '');
  return choice ? { prompt: q.prompt, choice } : null;
}).filter((x): x is { prompt: string; choice: ReturnType<typeof findChoice> & object } => x !== null);

const pageTitle = `How ${firstName} loves — a love profile · Far Fox`;
const pageDesc = tagline;
// Per-profile OG image: dynamic endpoint at /profile/<slug>/og.png
// renders the user's name + chosen emojis into a 1200x630 PNG so
// previews in iMessage / Twitter / Discord show *their* profile,
// not the generic brand card.
const ogImage = `https://lovefarfox.com/profile/${slug}/og.png`;
---

<Layout title={pageTitle} description={pageDesc} image={ogImage}>
  <main class="min-h-screen pt-24 pb-20 px-6 bg-gradient-to-b from-fox-bg via-white to-fox-bg">
    <div class="max-w-2xl mx-auto">
      <!-- "Just made it" banner — only on the redirect from /quiz.
           Loud, congratulatory, with the share + signup CTAs that
           normally sit at the bottom pulled up where the user can't
           miss them. -->
      {isFreshResult && (
        <div class="mb-8 rounded-3xl bg-gradient-to-br from-fox-pink/15 via-fox-purple/12 to-fox-orange/15 border-2 border-fox-pink/30 p-6 text-center">
          <div class="text-3xl mb-2">🎉</div>
          <h2 class="text-xl sm:text-2xl font-900 text-fox-text mb-2 leading-snug">
            Here's your love profile, {firstName}.
          </h2>
          <p class="text-fox-text-light text-sm leading-snug mb-4 max-w-sm mx-auto">
            Send it to your person. When they take theirs, you'll see how you match.
          </p>
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-3 justify-center items-stretch sm:items-center">
            <a
              href={`https://app.lovefarfox.com/signup?ref=quiz&slug=${slug}`}
              class="px-6 py-3 rounded-full bg-gradient-to-r from-fox-pink to-fox-purple text-white font-900 text-sm hover:shadow-xl hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5"
            >
              Save & connect with your partner →
            </a>
            <a
              href="#share"
              data-share-url={`https://lovefarfox.com/profile/${slug}`}
              class="quiz-share-btn px-6 py-3 rounded-full bg-white border-2 border-fox-pink/30 text-fox-text font-800 text-sm hover:border-fox-pink hover:-translate-y-0.5 transition-all duration-200"
            >
              📤 Share this link
            </a>
          </div>
        </div>
      )}

      <!-- Header — branded fox above the eyebrow so the page feels
           like Far Fox, not a generic love quiz. -->
      <div class="text-center mb-10">
        <img
          src="/fox-face.png"
          alt="Far Fox companion"
          class="w-24 h-24 sm:w-28 sm:h-28 mx-auto mb-4 drop-shadow-lg"
          width="112"
          height="112"
        />
        <div class="uppercase tracking-[0.3em] text-xs font-900 text-fox-pink mb-2">
          A Love Profile
        </div>
        <h1 class="text-4xl sm:text-5xl font-900 tracking-tight mb-3 leading-tight">
          How <span class="bg-gradient-to-r from-fox-pink via-fox-purple to-fox-orange bg-clip-text text-transparent">{firstName}</span> is wired to love
        </h1>
        <p class="text-fox-text-light text-lg italic max-w-md mx-auto leading-snug">
          {tagline}
        </p>
      </div>

      <!-- Answer cards -->
      <div class="space-y-3 mb-10">
        {answered.map(({ prompt, choice }) => (
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-fox-pink/10 flex items-center gap-4">
            <div class="text-4xl flex-shrink-0">{choice.emoji}</div>
            <div class="flex-1 min-w-0">
              <div class="text-[11px] font-700 tracking-wide uppercase text-fox-text-light/70 mb-1">
                {prompt}
              </div>
              <div class="text-lg font-800 text-fox-text leading-tight">
                {choice.label}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Take-yours CTA — the whole point of this page existing -->
      <div class="bg-gradient-to-br from-fox-pink to-fox-purple rounded-3xl p-8 text-center text-white shadow-2xl shadow-fox-pink/30 relative overflow-hidden">
        <!-- Subtle glow behind the fox -->
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-40 h-40 bg-white/15 rounded-full blur-2xl"></div>
        <img
          src="/fox-letter.png"
          alt="Far Fox messenger holding a love letter"
          class="relative w-24 h-24 mx-auto mb-3 drop-shadow-xl"
          width="96"
          height="96"
        />
        <h2 class="text-2xl sm:text-3xl font-900 mb-3 leading-tight relative">
          Find out how you love.
        </h2>
        <p class="text-white/90 mb-6 max-w-sm mx-auto leading-snug">
          Six honest questions. Two minutes. Shareable result. Make one with the person you love — or take it solo and send it their way.
        </p>
        <a
          href="https://app.lovefarfox.com/signup?ref=profile"
          class="inline-block px-8 py-3.5 rounded-full bg-white text-fox-pink font-900 text-lg hover:shadow-xl hover:shadow-black/20 transition-all duration-200 hover:-translate-y-0.5"
        >
          Make your love profile →
        </a>
        <div class="mt-3 text-xs text-white/70">
          Free · No ads · iOS, Android, Web
        </div>
      </div>

      <!-- Quiet brand footer back to landing -->
      <div class="text-center mt-10">
        <a href="/" class="text-fox-text-light/70 hover:text-fox-pink transition-colors text-sm font-700 inline-flex items-center gap-2">
          <img src="/fox-logo.png" alt="" class="w-5 h-5" />
          Made on Far Fox
        </a>
      </div>
    </div>
  </main>

  <script>
    // Native share where supported (iOS + Android Chrome), clipboard
    // fallback everywhere else. One tap → URL is in their hands.
    document.querySelectorAll<HTMLAnchorElement>('.quiz-share-btn').forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        const url = btn.dataset.shareUrl;
        if (!url) return;
        const navAny = navigator as Navigator & { share?: (data: ShareData) => Promise<void> };
        if (typeof navAny.share === 'function') {
          try {
            await navAny.share({
              title: 'My love profile',
              text: 'Here\'s how I feel loved 💕',
              url,
            });
          } catch (_) {
            // user dismissed — no-op
          }
          return;
        }
        try {
          await navigator.clipboard.writeText(url);
          const original = btn.textContent;
          btn.textContent = '✓ Link copied';
          setTimeout(() => { btn.textContent = original; }, 1800);
        } catch (_) {
          alert(url);
        }
      });
    });
  </script>
</Layout>
