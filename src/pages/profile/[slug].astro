---
import Layout from '../../layouts/Layout.astro';
import { fetchProfileBySlug } from '../../lib/supabase';
import {
  RITUAL_QUESTIONS,
  findChoice,
  ritualsTagline,
} from '../../lib/connectionRituals';

// SSR — the profile data needs to live in HTML for OG previews to
// resolve when this URL is shared on social. Static gen would be
// stale; we want live data per slug.
export const prerender = false;

const { slug } = Astro.params;

if (!slug || typeof slug !== 'string') {
  return Astro.redirect('/404');
}

const profile = await fetchProfileBySlug(slug);

if (!profile || !profile.connection_rituals) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

const firstName = profile.name.split(' ')[0];
const answers = profile.connection_rituals;
const tagline = ritualsTagline(answers);

// Build the answered list once for clean rendering below.
const answered = RITUAL_QUESTIONS.map((q) => {
  const choice = findChoice(q.key, answers[q.key] ?? '');
  return choice ? { prompt: q.prompt, choice } : null;
}).filter((x): x is { prompt: string; choice: ReturnType<typeof findChoice> & object } => x !== null);

const pageTitle = `How ${firstName} loves — a love profile · Far Fox`;
const pageDesc = tagline;
// Per-profile OG image. Falls back to the brand image until we ship a
// dedicated /og endpoint that renders the profile into a 1200x630 PNG.
const ogImage = 'https://lovefarfox.com/og-image.png';
---

<Layout title={pageTitle} description={pageDesc} image={ogImage}>
  <main class="min-h-screen pt-24 pb-20 px-6 bg-gradient-to-b from-fox-bg via-white to-fox-bg">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-10">
        <div class="text-6xl mb-4">💕</div>
        <div class="uppercase tracking-[0.3em] text-xs font-900 text-fox-pink mb-2">
          A Love Profile
        </div>
        <h1 class="text-4xl sm:text-5xl font-900 tracking-tight mb-3 leading-tight">
          How <span class="bg-gradient-to-r from-fox-pink via-fox-purple to-fox-orange bg-clip-text text-transparent">{firstName}</span> is wired to love
        </h1>
        <p class="text-fox-text-light text-lg italic max-w-md mx-auto leading-snug">
          {tagline}
        </p>
      </div>

      <!-- Answer cards -->
      <div class="space-y-3 mb-10">
        {answered.map(({ prompt, choice }) => (
          <div class="bg-white rounded-2xl p-5 shadow-sm border border-fox-pink/10 flex items-center gap-4">
            <div class="text-4xl flex-shrink-0">{choice.emoji}</div>
            <div class="flex-1 min-w-0">
              <div class="text-[11px] font-700 tracking-wide uppercase text-fox-text-light/70 mb-1">
                {prompt}
              </div>
              <div class="text-lg font-800 text-fox-text leading-tight">
                {choice.label}
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Take-yours CTA — the whole point of this page existing -->
      <div class="bg-gradient-to-br from-fox-pink to-fox-purple rounded-3xl p-8 text-center text-white shadow-2xl shadow-fox-pink/30">
        <div class="text-5xl mb-3">🦊</div>
        <h2 class="text-2xl sm:text-3xl font-900 mb-3 leading-tight">
          Find out how you love.
        </h2>
        <p class="text-white/90 mb-6 max-w-sm mx-auto leading-snug">
          Six honest questions. Two minutes. Shareable result. Make one with the person you love — or take it solo and send it their way.
        </p>
        <a
          href="https://app.lovefarfox.com/signup?ref=profile"
          class="inline-block px-8 py-3.5 rounded-full bg-white text-fox-pink font-900 text-lg hover:shadow-xl hover:shadow-black/20 transition-all duration-200 hover:-translate-y-0.5"
        >
          Make your love profile →
        </a>
        <div class="mt-3 text-xs text-white/70">
          Free · No ads · iOS, Android, Web
        </div>
      </div>

      <!-- Quiet brand footer back to landing -->
      <div class="text-center mt-10">
        <a href="/" class="text-fox-text-light/70 hover:text-fox-pink transition-colors text-sm font-700 inline-flex items-center gap-2">
          <img src="/fox-logo.png" alt="" class="w-5 h-5" />
          Made on Far Fox
        </a>
      </div>
    </div>
  </main>
</Layout>
