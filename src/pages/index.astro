---
import Layout from '../layouts/Layout.astro';

const faqs = [
  {
    question: 'Is Far Fox free?',
    answer: 'Yes! Far Fox is free to use with all core features included — shared photos, love letters, daily questions, mood tracking, challenges, and your fox companion. No hidden paywalls.',
  },
  {
    question: 'Does Far Fox work for military couples?',
    answer: 'Absolutely. Far Fox was designed for any couple spending time apart — military deployments, studying abroad, work travel, or any long-distance situation. Features like timezone awareness and async daily questions work great across time zones.',
  },
  {
    question: 'Do both partners need to sign up?',
    answer: 'Yes, both partners create their own account and connect via an invite link. Once connected, you share a fox companion and can see each other\'s photos, letters, and question answers.',
  },
  {
    question: 'What makes Far Fox different from texting or FaceTime?',
    answer: 'Far Fox isn\'t a messaging app — it\'s a relationship app. Daily prompts, love letter stationery, shared challenges, mood tracking, and a fox that grows with your relationship create daily rituals that texting can\'t replicate.',
  },
  {
    question: 'Is my data private?',
    answer: 'Your content is shared only with your connected partner — no one else can see it. We don\'t sell data, run ads, or use third-party trackers. See our privacy policy for full details.',
  },
  {
    question: 'What platforms does Far Fox support?',
    answer: 'Far Fox works on the web (any browser), iOS, and Android. Your data syncs across all devices automatically.',
  },
];

const featureGroups = [
  {
    title: 'Daily Connection',
    description: 'Small daily touchpoints that make distance feel smaller.',
    features: [
      {
        emoji: '💬',
        title: 'Daily Questions',
        description: 'Answer fun and deep questions together. See each other\'s answers once you\'ve both responded.',
      },
      {
        emoji: '📸',
        title: 'Shared Photos',
        description: 'Snap and share moments throughout your day. Build a private photo timeline together.',
      },
      {
        emoji: '🎙️',
        title: 'Voice & Video Messages',
        description: 'Leave voice notes and short video messages. Hear their voice whenever you need it — no call required.',
      },
      {
        emoji: '💛',
        title: 'Thinking of You',
        description: 'Send a quick tap. Your partner feels a buzz and knows you\'re thinking about them right now.',
      },
    ],
  },
  {
    title: 'Write & Reflect',
    description: 'Quiet rituals for the things that need more than a text.',
    features: [
      {
        emoji: '💌',
        title: 'Love Letters',
        description: 'Write heartfelt letters on beautiful stationery themes. Daily prompts keep the words flowing.',
      },
      {
        emoji: '🔮',
        title: 'Time Capsule',
        description: 'Seal a message to be opened on a future date. A love letter your future selves will read together.',
      },
      {
        emoji: '🌙',
        title: 'Mood & Presence',
        description: 'Share how you\'re feeling. See when your partner is online and what timezone they\'re in.',
      },
    ],
  },
  {
    title: 'Play Together',
    description: 'Games and challenges that turn screen time into shared time.',
    features: [
      {
        emoji: '🔥',
        title: 'Would You Rather',
        description: 'Play rounds of Would You Rather and see how well you match. Spoiler: it\'s never 100%.',
      },
      {
        emoji: '🧩',
        title: 'Couple Quizzes',
        description: 'Compatibility quizzes that reveal how well you really know each other. Compare answers side by side.',
      },
      {
        emoji: '🎯',
        title: 'Challenges & Streaks',
        description: 'Daily challenges that integrate with the app. Take a photo, write a letter, answer a question — earn XP.',
      },
      {
        emoji: '🐾',
        title: 'Your Fox Companion',
        description: 'A little fox that grows with your relationship. It reacts to everything you do — pet it, feed it love.',
      },
    ],
  },
  {
    title: 'Plan Together',
    description: 'Look forward to the next time you\'re in the same place.',
    features: [
      {
        emoji: '📅',
        title: 'Plans & Countdowns',
        description: 'Track your next visit, anniversaries, and special dates. The countdown makes it real.',
      },
      {
        emoji: '🗓️',
        title: 'Shared Calendar',
        description: 'Plan visits, mark anniversaries, and sync your schedules. No more "I didn\'t know you had that."',
      },
      {
        emoji: '🦊',
        title: 'Ask Foxy',
        description: 'Your AI relationship companion. Ask for advice, date ideas, or just vent — Foxy gets your situation.',
      },
    ],
  },
];
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 backdrop-blur-md bg-fox-bg/80 border-b border-fox-pink/10">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/fox-logo.png" alt="Far Fox — couples app for long-distance relationships" class="w-8 h-8" />
        <span class="text-xl font-900 tracking-tight bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">
          Far Fox
        </span>
      </a>
      <a
        href="https://app.lovefarfox.com"
        class="px-5 py-2 rounded-full bg-fox-pink text-white font-700 text-sm hover:bg-fox-purple hover:shadow-lg hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5"
      >
        Open App
      </a>
    </div>
  </nav>

  <!-- Hero -->
  <section class="min-h-screen flex items-center justify-center pt-20 pb-16 px-6 relative overflow-hidden">
    <!-- Subtle gradient orbs -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-fox-pink/10 rounded-full blur-3xl will-change-transform"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-fox-purple/10 rounded-full blur-3xl will-change-transform"></div>
    <div class="absolute top-40 right-20 w-48 h-48 bg-fox-orange/15 rounded-full blur-3xl will-change-transform"></div>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: text + CTA -->
        <div class="text-center lg:text-left">
          <img src="/fox-logo.png" alt="Far Fox kawaii fox mascot — the couples app for staying connected long distance" class="w-20 h-20 mx-auto lg:mx-0 mb-6 drop-shadow-lg fade-in fox-float" width="80" height="80" />
          <h1 class="text-4xl sm:text-5xl md:text-6xl font-900 leading-tight tracking-tight mb-6 fade-in" style="animation-delay: 0.1s;">
            Daily rituals for couples who
            <span class="bg-gradient-to-r from-fox-pink via-fox-purple to-fox-orange bg-clip-text text-transparent">
              live apart
            </span>
          </h1>
          <p class="text-lg sm:text-xl text-fox-text-light max-w-xl mx-auto lg:mx-0 mb-8 leading-relaxed fade-in" style="animation-delay: 0.2s;">
            Far Fox is more than messaging. Daily questions, love letters,
            shared photos, voice notes, and a fox that grows with your
            relationship — built for couples who refuse to drift.
          </p>
          <div class="flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4 fade-in" style="animation-delay: 0.3s;">
            <div class="flex flex-col items-center sm:items-start">
              <a
                href="https://app.lovefarfox.com"
                class="px-8 py-3.5 rounded-full bg-fox-pink text-white font-800 text-lg hover:bg-fox-purple hover:shadow-xl hover:shadow-fox-pink/40 transition-all duration-200 hover:-translate-y-0.5"
              >
                Try Far Fox Free
              </a>
              <div class="flex items-center gap-1.5 mt-2 text-xs text-fox-text-light/70">
                <span class="inline-block w-1.5 h-1.5 rounded-full bg-green-500"></span>
                <span class="font-700">100% free</span>
                <span>·</span>
                <span>No ads</span>
                <span>·</span>
                <span>iOS, Android, Web</span>
              </div>
            </div>
            <a
              href="#features"
              class="px-8 py-3.5 rounded-full border-2 border-fox-pink/20 text-fox-text font-700 text-lg hover:border-fox-pink/40 transition-all duration-200"
            >
              See Features
            </a>
          </div>
        </div>

        <!-- Right: phone screenshot mockup -->
        <div class="flex justify-center lg:justify-end fade-in" style="animation-delay: 0.4s;">
          <div class="relative">
            <!-- Soft glow behind phone -->
            <div class="absolute inset-0 bg-gradient-to-br from-fox-pink/20 via-fox-purple/15 to-fox-orange/15 blur-3xl scale-110"></div>
            <!-- Phone frame -->
            <div class="relative bg-fox-text rounded-[2.5rem] p-2 shadow-2xl shadow-fox-pink/25 w-[280px]">
              <div class="relative rounded-[2rem] overflow-hidden w-full" style="aspect-ratio: 928 / 1698;">
                <img src="/screenshots/hero-home.png" alt="Far Fox app home, love letters, explore activities, travel map, and would you rather screens" class="hero-screen absolute inset-0 w-full h-full transition-opacity duration-[800ms] ease-in-out" style="opacity: 1;" />
                <img src="/screenshots/love-letters.png" alt="" class="hero-screen absolute inset-0 w-full h-full transition-opacity duration-[800ms] ease-in-out" style="opacity: 0;" loading="lazy" />
                <img src="/screenshots/explore.png" alt="" class="hero-screen absolute inset-0 w-full h-full transition-opacity duration-[800ms] ease-in-out" style="opacity: 0;" loading="lazy" />
                <img src="/screenshots/travel-map.png" alt="" class="hero-screen absolute inset-0 w-full h-full transition-opacity duration-[800ms] ease-in-out" style="opacity: 0;" loading="lazy" />
                <img src="/screenshots/would-you-rather.png" alt="" class="hero-screen absolute inset-0 w-full h-full transition-opacity duration-[800ms] ease-in-out" style="opacity: 0;" loading="lazy" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- App showcase -->
  <section class="py-24 px-6 bg-gradient-to-b from-fox-bg/0 via-fox-pink/5 to-fox-bg/0">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-900 tracking-tight mb-4 scroll-reveal">
          See it in
          <span class="bg-gradient-to-r from-fox-pink to-fox-orange bg-clip-text text-transparent">action</span>
        </h2>
        <p class="text-fox-text-light text-lg max-w-lg mx-auto scroll-reveal">
          Real screens from real couples. Built for daily use, not occasional notifications.
        </p>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 sm:gap-8">
        <div class="scroll-reveal" style="transition-delay: 0.05s;">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-fox-pink/20 to-fox-purple/15 blur-2xl scale-105"></div>
            <div class="relative bg-fox-text rounded-2xl sm:rounded-3xl p-1.5 shadow-xl shadow-fox-pink/15">
              <img src="/screenshots/love-letters.png" alt="Love Letters exchange screen showing back-and-forth letters between partners" class="rounded-xl sm:rounded-2xl w-full block" loading="lazy" />
            </div>
          </div>
          <p class="text-center mt-4 text-sm font-700 text-fox-text-light">💌 Love Letters</p>
        </div>

        <div class="scroll-reveal" style="transition-delay: 0.1s;">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-fox-purple/20 to-fox-pink/15 blur-2xl scale-105"></div>
            <div class="relative bg-fox-text rounded-2xl sm:rounded-3xl p-1.5 shadow-xl shadow-fox-purple/15">
              <img src="/screenshots/explore.png" alt="Explore screen showing Quizzes, Would You Rather, Challenges, Cool Down, Photos, and Questions" class="rounded-xl sm:rounded-2xl w-full block" loading="lazy" />
            </div>
          </div>
          <p class="text-center mt-4 text-sm font-700 text-fox-text-light">✨ Explore Activities</p>
        </div>

        <div class="scroll-reveal" style="transition-delay: 0.15s;">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-fox-orange/20 to-fox-pink/15 blur-2xl scale-105"></div>
            <div class="relative bg-fox-text rounded-2xl sm:rounded-3xl p-1.5 shadow-xl shadow-fox-orange/15">
              <img src="/screenshots/travel-map.png" alt="Travel map showing planned trips and visits between long-distance partners" class="rounded-xl sm:rounded-2xl w-full block" loading="lazy" />
            </div>
          </div>
          <p class="text-center mt-4 text-sm font-700 text-fox-text-light">🗺️ Travel Map</p>
        </div>

        <div class="scroll-reveal" style="transition-delay: 0.2s;">
          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-fox-pink/20 to-fox-purple/15 blur-2xl scale-105"></div>
            <div class="relative bg-fox-text rounded-2xl sm:rounded-3xl p-1.5 shadow-xl shadow-fox-pink/15">
              <img src="/screenshots/would-you-rather.png" alt="Would You Rather game screen showing match stats and daily questions" class="rounded-xl sm:rounded-2xl w-full block" loading="lazy" />
            </div>
          </div>
          <p class="text-center mt-4 text-sm font-700 text-fox-text-light">🔥 Would You Rather</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl sm:text-4xl font-900 tracking-tight mb-4">
          Everything you need to
          <span class="bg-gradient-to-r from-fox-pink to-fox-orange bg-clip-text text-transparent">stay close</span>
        </h2>
        <p class="text-fox-text-light text-lg max-w-lg mx-auto">
          Not just another messaging app. Far Fox is built from the ground up for couples who live apart.
        </p>
      </div>

      <div class="space-y-16">
        {featureGroups.map((group) => (
          <div>
            <div class="text-center mb-8 scroll-reveal">
              <h3 class="text-2xl sm:text-3xl font-900 tracking-tight mb-2">
                <span class="bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">{group.title}</span>
              </h3>
              <p class="text-fox-text-light text-base max-w-md mx-auto">{group.description}</p>
            </div>
            <div class={`grid grid-cols-1 sm:grid-cols-2 gap-6 ${group.features.length === 4 ? 'lg:grid-cols-4' : 'lg:grid-cols-3 max-w-4xl mx-auto'}`}>
              {group.features.map((f, i) => (
                <div class="group p-6 rounded-2xl bg-white/70 border border-fox-pink/8 hover:border-fox-pink/20 hover:shadow-lg hover:shadow-fox-pink/8 transition-all duration-200 hover:-translate-y-1 scroll-reveal" style={`transition-delay: ${i * 0.05}s;`}>
                  <div class="text-3xl mb-3">{f.emoji}</div>
                  <h4 class="font-800 text-lg mb-2">{f.title}</h4>
                  <p class="text-fox-text-light text-sm leading-relaxed">{f.description}</p>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="py-24 px-6 bg-gradient-to-b from-fox-bg to-white">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-900 tracking-tight mb-16 scroll-reveal">
        Getting started is
        <span class="bg-gradient-to-r from-fox-purple to-fox-pink bg-clip-text text-transparent">easy</span>
      </h2>

      <div class="flex flex-col sm:flex-row gap-12 sm:gap-8">
        <div class="flex-1 flex flex-col items-center scroll-reveal" style="transition-delay: 0.1s;">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-fox-pink to-fox-purple flex items-center justify-center text-white font-900 text-xl mb-4">1</div>
          <h3 class="font-800 text-xl mb-2">Name your fox</h3>
          <p class="text-fox-text-light max-w-sm">Sign up and choose a name for the fox companion that'll grow with your relationship.</p>
        </div>
        <!-- Connector arrow (hidden on mobile) -->
        <div class="hidden sm:flex items-center justify-center text-fox-pink/20 -mx-2 pt-0 mt-2">
          <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="flex-1 flex flex-col items-center scroll-reveal" style="transition-delay: 0.2s;">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-fox-orange to-fox-pink flex items-center justify-center text-white font-900 text-xl mb-4">2</div>
          <h3 class="font-800 text-xl mb-2">Connect with your partner</h3>
          <p class="text-fox-text-light max-w-sm">Send an invite link. Once they join, your fox wakes up and your first daily question drops.</p>
        </div>
        <div class="hidden sm:flex items-center justify-center text-fox-pink/20 -mx-2 pt-0 mt-2">
          <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28m0 0l-6-6m6 6l-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="flex-1 flex flex-col items-center scroll-reveal" style="transition-delay: 0.3s;">
          <div class="w-14 h-14 rounded-full bg-gradient-to-br from-fox-purple to-fox-orange flex items-center justify-center text-white font-900 text-xl mb-4">3</div>
          <h3 class="font-800 text-xl mb-2">Build your rituals</h3>
          <p class="text-fox-text-light max-w-sm">Answer questions, write love letters, complete challenges together — level up your fox and your streak.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- What is Far Fox — SEO content section -->
  <section class="py-20 px-6">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-900 tracking-tight mb-6 scroll-reveal">
        Built for the
        <span class="bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">distance</span>
      </h2>
      <p class="text-fox-text-light text-lg leading-relaxed scroll-reveal max-w-2xl mx-auto">
        Whether you're a long-distance couple, a military spouse, studying abroad, or
        just spending a few weeks apart — Far Fox replaces transactional texting with
        rituals that actually keep you close. No ads, no algorithms, no distractions —
        just you, your partner, and your fox.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-24 px-6 bg-gradient-to-b from-fox-bg to-white">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-900 tracking-tight mb-12 text-center">
        Frequently asked
        <span class="bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">questions</span>
      </h2>

      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-2xl bg-white/70 border border-fox-pink/8 hover:border-fox-pink/20 transition-all duration-200">
            <summary class="flex items-center justify-between p-6 cursor-pointer font-800 text-lg list-none [&::-webkit-details-marker]:hidden">
              {faq.question}
              <span class="ml-4 text-fox-pink/40 group-open:rotate-45 transition-transform duration-200 text-2xl font-700">+</span>
            </summary>
            <div class="px-6 pb-6 text-fox-text-light leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
      "@type": "Question",
      "name": faq.question,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": faq.answer,
      },
    })),
  })} />

  <!-- CTA -->
  <section class="py-24 px-6 bg-gradient-to-b from-white to-fox-bg">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-3xl sm:text-4xl font-900 tracking-tight mb-4">
        Your fox is waiting
      </h2>
      <p class="text-fox-text-light text-lg mb-10 max-w-md mx-auto">
        Join couples who are making long-distance a little more bearable, one letter at a time.
      </p>
      <a
        href="https://app.lovefarfox.com"
        class="inline-block px-10 py-4 rounded-full bg-fox-pink text-white font-800 text-lg hover:bg-fox-purple hover:shadow-xl hover:shadow-fox-pink/40 transition-all duration-200 hover:-translate-y-0.5"
      >
        Try Far Fox Free
      </a>
      <p class="mt-4 text-sm text-fox-text-light/70">
        Free · iOS, Android, Web · No ads
      </p>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-fox-pink/10">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-800 text-lg bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">Far Fox</span>
      <div class="flex items-center gap-6 text-sm text-fox-text-light/50">
        <a href="/blog" class="hover:text-fox-pink transition-colors">Blog</a>
        <a href="/privacy" class="hover:text-fox-pink transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-fox-pink transition-colors">Terms</a>
        <a href="mailto:blake@lovefarfox.com" class="hover:text-fox-pink transition-colors">Contact</a>
        <span>&copy; {new Date().getFullYear()} Far Fox</span>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Fade-in on load */
  .fade-in {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeInUp 0.6s ease forwards;
  }

  @keyframes fadeInUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Floating fox with personality */
  .fox-float {
    animation: fadeInUp 0.6s ease forwards, foxIdle 5s ease-in-out 0.6s infinite;
    transform-origin: center bottom;
    cursor: pointer;
    will-change: transform;
    transition: transform 0.2s ease-out;
  }

  /* Gentle bob + subtle tilt (like the fox is looking around) */
  @keyframes foxIdle {
    0%, 100% { transform: translateY(0) rotate(-1.5deg); }
    25%      { transform: translateY(-6px) rotate(0.5deg); }
    50%      { transform: translateY(-10px) rotate(1.5deg); }
    75%      { transform: translateY(-6px) rotate(-0.5deg); }
  }

  /* Hover: excited wiggle */
  .fox-float:hover {
    animation: fadeInUp 0.6s ease forwards, foxWiggle 0.6s ease-in-out;
  }

  @keyframes foxWiggle {
    0%, 100% { transform: translateY(-6px) rotate(0) scale(1.05); }
    20%      { transform: translateY(-12px) rotate(-8deg) scale(1.08); }
    40%      { transform: translateY(-6px) rotate(6deg) scale(1.08); }
    60%      { transform: translateY(-10px) rotate(-4deg) scale(1.06); }
    80%      { transform: translateY(-6px) rotate(2deg) scale(1.05); }
  }

  /* Click: boop! */
  .fox-float.fox-booped {
    animation: foxBoop 0.5s ease-out !important;
  }

  @keyframes foxBoop {
    0%   { transform: translateY(-6px) rotate(0) scale(1); }
    30%  { transform: translateY(2px) rotate(-3deg) scale(0.92); }
    60%  { transform: translateY(-16px) rotate(8deg) scale(1.12); }
    100% { transform: translateY(0) rotate(-1.5deg) scale(1); }
  }

  /* Scroll reveal */
  .scroll-reveal {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .scroll-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .fade-in,
    .fox-float,
    .scroll-reveal {
      opacity: 1;
      transform: none;
      animation: none;
      transition: none;
    }
  }

  /* No-JS fallback: show content if JS doesn't run */
  @media (scripting: none) {
    .scroll-reveal {
      opacity: 1;
      transform: none;
    }
  }
</style>

<noscript>
  <style>
    .scroll-reveal {
      opacity: 1 !important;
      transform: none !important;
    }
  </style>
</noscript>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document.querySelectorAll('.scroll-reveal').forEach((el) => observer.observe(el));

  // Hero phone screen cycle
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const heroScreens = document.querySelectorAll<HTMLImageElement>('.hero-screen');
  if (!prefersReducedMotion && heroScreens.length > 1) {
    let current = 0;
    setInterval(() => {
      heroScreens[current].style.opacity = '0';
      current = (current + 1) % heroScreens.length;
      heroScreens[current].style.opacity = '1';
    }, 4000);
  }

  // Boop the fox: click for a little reaction
  const fox = document.querySelector<HTMLImageElement>('.fox-float');
  if (fox && !prefersReducedMotion) {
    fox.addEventListener('click', () => {
      fox.classList.remove('fox-booped');
      // force reflow so the animation can re-trigger
      void fox.offsetWidth;
      fox.classList.add('fox-booped');
    });
    fox.addEventListener('animationend', (e) => {
      if ((e as AnimationEvent).animationName === 'foxBoop') {
        fox.classList.remove('fox-booped');
      }
    });
  }
</script>
