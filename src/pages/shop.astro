---
import Layout from '../layouts/Layout.astro';
import catalog from '../data/catalog.json';
import { kitSlugForName } from '../lib/kits.mjs';

/**
 * Far Fox Shop — print-on-demand storefront.
 *
 * Cart + checkout run on Snipcart (static-site friendly, integrates with
 * Printful for automatic fulfillment). The whole storefront UI is built
 * here; going live needs exactly two things from the owner:
 *   1. A Snipcart PUBLIC API key  → set PUBLIC_SNIPCART_KEY in the env
 *      (Vercel → Settings → Environment Variables), and
 *   2. Connect Printful inside the Snipcart dashboard so orders fulfill
 *      automatically.
 * Until a key is set, the page renders fully; the cart simply stays inert
 * (we show a small "preview" notice instead of a broken checkout).
 *
 * Snipcart validates prices by crawling each item's `data-item-url`. Every
 * product here uses /shop as its url and the matching button lives on this
 * page, so validation resolves against this same page. Prices are the
 * single source of truth in the PRODUCTS array below.
 */

// Snipcart PUBLIC API key — safe to ship in client HTML (that's how the
// cart works). Env var wins if set in Vercel; otherwise this default.
const SNIPCART_KEY = import.meta.env.PUBLIC_SNIPCART_KEY ?? 'ZDBhODA3ZGEtNzM5Zi00MGYxLTg4ODItOGY3NTYyMTQwNmRmNjM5MTYzNzE4NTA1NTczODE3';
const cartLive = SNIPCART_KEY.length > 0;

const SITE = 'https://lovefarfox.com';

type Product = {
  id: string;
  slug: string;
  name: string;
  price: number;
  currency?: string;
  image: string;
  back?: string | null;
  sizes?: string[];
  colors?: { name: string; hex: string }[];
};

// Catalog is generated from Printful at build time (scripts/sync-catalog.mjs):
// every sync product in the store, with its price, sizes and mockup. Add,
// edit or remove products in the Printful dashboard — nothing here changes.
const PRODUCTS: Product[] = (catalog.products as Product[]);

const fmt = (n: number) => (Number.isInteger(n) ? `$${n}` : `$${n.toFixed(2)}`);

// Group products into shoppable categories (first match wins, jerseys lead).
const CATS: { title: string; test: (n: string) => boolean }[] = [
  { title: 'Jerseys', test: (n) => /jersey/i.test(n) },
  { title: 'Tees & Hoodies', test: (n) => /tee|hoodie/i.test(n) },
  { title: 'Mugs', test: (n) => /mug/i.test(n) },
  { title: 'Art Prints', test: (n) => /print/i.test(n) },
  { title: 'Stickers', test: (n) => /sticker/i.test(n) },
];
const catOf = (n: string) => CATS.find((c) => c.test(n))?.title ?? 'More';
const grouped = [...CATS.map((c) => c.title), 'More']
  .map((title) => ({ title, items: PRODUCTS.filter((p) => catOf(p.name) === title) }))
  .filter((g) => g.items.length);
---

<Layout
  title="Far Fox Shop — Jerseys, Tees, Mugs, Prints & Stickers"
  description="Official Far Fox merch for long-distance couples: Far Fox FC soccer jerseys, baseball jerseys, tees, hoodies, mugs, art prints, and stickers. Printed to order, ships worldwide."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": "Far Fox Shop",
      "url": "https://lovefarfox.com/shop",
      "numberOfItems": PRODUCTS.length,
      "itemListElement": PRODUCTS.map((p, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "Product",
          "name": p.name,
          "image": `${SITE}${p.image}`,
          "url": "https://lovefarfox.com/shop",
          "brand": { "@type": "Brand", "name": "Far Fox" },
          "offers": {
            "@type": "Offer",
            "price": p.price,
            "priceCurrency": p.currency || "USD",
            "availability": "https://schema.org/InStock",
          },
        },
      })),
    })} />
  </Fragment>
  {cartLive && (
    <Fragment slot="head">
      <link rel="preconnect" href="https://app.snipcart.com" />
      <link rel="preconnect" href="https://cdn.snipcart.com" />
      <link rel="stylesheet" href="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.css" />
    </Fragment>
  )}

  <!-- Nav -->
  <nav class="fixed top-0 w-full z-50 backdrop-blur-md bg-fox-bg/80 border-b border-fox-pink/10">
    <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2">
        <img src="/fox-logo.png" alt="Far Fox" class="w-8 h-8" />
        <span class="text-xl font-900 tracking-tight bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">
          Far Fox
        </span>
      </a>
      <div class="flex items-center gap-4">
        <a href="/blog" class="hidden sm:inline text-sm font-700 text-fox-text-light hover:text-fox-pink transition-colors">Blog</a>
        {cartLive && (
          <button class="snipcart-checkout flex items-center gap-1.5 text-sm font-800 text-fox-text hover:text-fox-pink transition-colors">
            <span aria-hidden="true">🛒</span>
            Cart (<span class="snipcart-items-count">0</span>)
          </button>
        )}
        <a
          href="https://app.lovefarfox.com"
          class="px-5 py-2 rounded-full bg-fox-pink text-white font-700 text-sm hover:bg-fox-purple hover:shadow-lg hover:shadow-fox-pink/30 transition-all duration-200 hover:-translate-y-0.5"
        >
          Open App
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="pt-32 pb-12 px-6 text-center relative overflow-hidden">
    <div class="absolute top-10 left-1/4 w-72 h-72 bg-fox-pink/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-80 h-80 bg-fox-purple/10 rounded-full blur-3xl"></div>
    <div class="max-w-3xl mx-auto relative z-10">
      <img src="/fox-logo.png" alt="Far Fox mascot" class="w-20 h-20 mx-auto mb-6 drop-shadow-lg" />
      <h1 class="text-4xl sm:text-5xl font-900 tracking-tight mb-4">
        The Far Fox
        <span class="bg-gradient-to-r from-fox-pink via-fox-purple to-fox-orange bg-clip-text text-transparent">Shop</span>
      </h1>
      <p class="text-fox-text-light text-lg max-w-xl mx-auto leading-relaxed">
        Carry the fox with you. Quality merch featuring the little companion that grows
        with your relationship — printed to order and shipped worldwide.
      </p>
      {!cartLive && (
        <p class="mt-6 inline-block text-sm font-700 text-fox-text-light/80 bg-fox-pink/10 border border-fox-pink/20 rounded-full px-4 py-1.5">
          🦊 Preview — checkout opens soon
        </p>
      )}
    </div>
  </section>

  <!-- Product grid, grouped by category -->
  <section class="pb-20 px-6">
    <div class="max-w-6xl mx-auto space-y-14 sm:space-y-20">
      {grouped.map((group) => (
      <div>
        <h2 class="text-2xl sm:text-3xl font-900 tracking-tight mb-6 sm:mb-8">{group.title}</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
          {group.items.map((p) => (
        <div class="group flex flex-col rounded-3xl bg-white/70 border border-fox-pink/10 overflow-hidden hover:border-fox-pink/25 hover:shadow-xl hover:shadow-fox-pink/10 transition-all duration-200 hover:-translate-y-1">
          <div class="relative aspect-square bg-gradient-to-br from-fox-bg to-white overflow-hidden">
            <img id={`img-${p.id}`} src={p.image} alt={p.name} class="w-full h-full object-contain p-2 transition-opacity duration-150" loading="lazy" />
            {p.name.includes('Pride') && (
              <span class="absolute top-3 left-3 text-xs font-800 uppercase tracking-wide text-white bg-fox-pink rounded-full px-3 py-1">Pride</span>
            )}
            {p.back && (
              <div class="absolute bottom-2 left-1/2 -translate-x-1/2 flex gap-1 bg-white/85 backdrop-blur rounded-full px-1.5 py-1 shadow-sm">
                <button type="button" class="view-btn text-[11px] font-800 px-2.5 py-0.5 rounded-full transition-colors" data-product={p.id} data-view={`${SITE}${p.image}`} data-active="true">Front</button>
                <button type="button" class="view-btn text-[11px] font-800 px-2.5 py-0.5 rounded-full transition-colors" data-product={p.id} data-view={`${SITE}${p.back}`} data-active="false">Back</button>
              </div>
            )}
          </div>
          <div class="flex flex-col flex-1 p-5">
            <div class="flex items-baseline justify-between gap-2 mb-3">
              <h2 class="font-800 text-lg leading-tight">{p.name}</h2>
              <span class="font-900 text-fox-pink whitespace-nowrap">{fmt(p.price)}</span>
            </div>
            <div class="flex-1"></div>

            {p.colors && p.colors.length > 0 && (
              <div class="mb-3">
                <div class="flex items-center justify-between mb-1.5">
                  <span class="text-xs font-700 uppercase tracking-wide text-fox-text-light">Color</span>
                  <span id={`color-label-${p.id}`} class="text-xs font-700 text-fox-text">{p.colors[0].name}</span>
                </div>
                <div class="flex flex-wrap gap-1.5" role="radiogroup" aria-label={`Color for ${p.name}`}>
                  {p.colors.map((c, i) => (
                    <button
                      type="button"
                      class="color-swatch w-6 h-6 rounded-full border transition-transform hover:scale-110"
                      data-product={p.id}
                      data-color={c.name}
                      data-image={c.image || p.image}
                      data-selected={i === 0 ? 'true' : 'false'}
                      title={c.name}
                      aria-label={c.name}
                      style={`background:${c.hex};border-color:${c.hex.toLowerCase() === '#ffffff' ? '#d8d2c8' : 'rgba(0,0,0,0.15)'};box-shadow:${i === 0 ? '0 0 0 2px #fff,0 0 0 4px var(--swatch-ring,#e0689a)' : 'none'}`}
                    ></button>
                  ))}
                </div>
                <input type="hidden" id={`color-${p.id}`} value={p.colors[0].name} />
              </div>
            )}

            {p.sizes && p.sizes.length > 0 && (
              <select
                id={`size-${p.id}`}
                class="mb-3 w-full rounded-xl border border-fox-pink/20 bg-white/80 px-3 py-2 text-sm font-700 text-fox-text focus:outline-none focus:border-fox-pink"
                aria-label={`Size for ${p.name}`}
              >
                {p.sizes.map((s) => <option value={s}>{`Size: ${s}`}</option>)}
              </select>
            )}

            {kitSlugForName(p.name) && (
              <div class="mb-3 rounded-xl border border-fox-pink/15 bg-fox-pink/[0.04] p-3">
                <div class="text-xs font-800 uppercase tracking-wide text-fox-text-light mb-2">
                  Personalize <span class="font-600 normal-case tracking-normal text-fox-text-light/70">· optional</span>
                </div>
                <div class="flex gap-2">
                  <input
                    id={`pname-${p.id}`}
                    type="text"
                    maxlength="14"
                    placeholder="Name"
                    aria-label={`Name on back for ${p.name}`}
                    class="flex-1 min-w-0 rounded-lg border border-fox-pink/20 bg-white/80 px-3 py-2 text-sm font-700 text-fox-text uppercase placeholder:normal-case placeholder:font-600 placeholder:text-fox-text-light/60 focus:outline-none focus:border-fox-pink"
                  />
                  <input
                    id={`pnum-${p.id}`}
                    type="text"
                    inputmode="numeric"
                    maxlength="3"
                    placeholder="#"
                    aria-label={`Number on back for ${p.name}`}
                    class="w-16 rounded-lg border border-fox-pink/20 bg-white/80 px-3 py-2 text-sm font-700 text-fox-text text-center placeholder:font-600 placeholder:text-fox-text-light/60 focus:outline-none focus:border-fox-pink"
                  />
                </div>
              </div>
            )}

            {cartLive ? (
              <button
                class="snipcart-add-item mt-auto w-full px-5 py-3 rounded-full bg-fox-pink text-white font-800 hover:bg-fox-purple hover:shadow-lg hover:shadow-fox-pink/30 transition-all duration-200"
                data-item-id={p.id}
                data-item-name={p.name}
                data-item-price={p.price}
                data-item-url="/shop"
                data-item-image={`${SITE}${p.image}`}
                data-item-description={p.name}
                data-item-custom1-name={p.sizes?.length ? 'Size' : undefined}
                data-item-custom1-options={p.sizes?.length ? p.sizes.join('|') : undefined}
                data-size-select={p.sizes?.length ? `size-${p.id}` : undefined}
                data-item-custom2-name={p.colors?.length ? 'Color' : undefined}
                data-item-custom2-options={p.colors?.length ? p.colors.map((c) => c.name).join('|') : undefined}
                data-item-custom2-value={p.colors?.length ? p.colors[0].name : undefined}
                data-color-input={p.colors?.length ? `color-${p.id}` : undefined}
                data-item-custom3-name={kitSlugForName(p.name) ? 'Name' : undefined}
                data-item-custom3-required={kitSlugForName(p.name) ? 'false' : undefined}
                data-name-input={kitSlugForName(p.name) ? `pname-${p.id}` : undefined}
                data-item-custom4-name={kitSlugForName(p.name) ? 'Number' : undefined}
                data-item-custom4-required={kitSlugForName(p.name) ? 'false' : undefined}
                data-number-input={kitSlugForName(p.name) ? `pnum-${p.id}` : undefined}
              >
                Add to cart
              </button>
            ) : (
              <button
                disabled
                class="mt-auto w-full px-5 py-3 rounded-full bg-fox-pink/30 text-white/90 font-800 cursor-not-allowed"
              >
                Coming soon
              </button>
            )}
          </div>
        </div>
          ))}
        </div>
      </div>
      ))}
    </div>
  </section>

  <!-- Quality / reassurance -->
  <section class="py-16 px-6 bg-gradient-to-b from-fox-bg to-white">
    <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-8 text-center">
      <div>
        <div class="text-3xl mb-3">✨</div>
        <h3 class="font-800 text-lg mb-1">Genuinely good quality</h3>
        <p class="text-fox-text-light text-sm leading-relaxed">Printed on premium blanks — soft cotton, hard enamel, weatherproof vinyl. No flimsy merch.</p>
      </div>
      <div>
        <div class="text-3xl mb-3">🌍</div>
        <h3 class="font-800 text-lg mb-1">Ships worldwide</h3>
        <p class="text-fox-text-light text-sm leading-relaxed">Printed to order near you and shipped almost anywhere — made for couples in two places.</p>
      </div>
      <div>
        <div class="text-3xl mb-3">🦊</div>
        <h3 class="font-800 text-lg mb-1">Supports the app</h3>
        <p class="text-fox-text-light text-sm leading-relaxed">Every order helps keep Far Fox free, with no ads and no selling your data.</p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-12 px-6 border-t border-fox-pink/10">
    <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-800 text-lg bg-gradient-to-r from-fox-pink to-fox-purple bg-clip-text text-transparent">Far Fox</span>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-fox-text-light/50">
        <a href="/shop" class="hover:text-fox-pink transition-colors">Shop</a>
        <a href="/blog" class="hover:text-fox-pink transition-colors">Blog</a>
        <a href="/privacy" class="hover:text-fox-pink transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-fox-pink transition-colors">Terms</a>
        <a href="mailto:blake@lovefarfox.com" class="hover:text-fox-pink transition-colors">Contact</a>
        <span>&copy; {new Date().getFullYear()} Far Fox</span>
      </div>
    </div>
  </footer>

  {cartLive && (
    <Fragment>
      <div hidden id="snipcart" data-api-key={SNIPCART_KEY} data-config-modal-style="side"></div>
      <script is:inline src="https://cdn.snipcart.com/themes/v3.7.1/default/snipcart.js"></script>
      <script is:inline>
        // Colour swatch selection: update the hidden input, the label and the
        // selected ring for the product the swatch belongs to.
        document.querySelectorAll('.color-swatch').forEach((sw) => {
          sw.addEventListener('click', () => {
            const pid = sw.getAttribute('data-product');
            const name = sw.getAttribute('data-color');
            document.querySelectorAll(`.color-swatch[data-product="${pid}"]`).forEach((s) => {
              s.setAttribute('data-selected', 'false');
              s.style.boxShadow = 'none';
            });
            sw.setAttribute('data-selected', 'true');
            sw.style.boxShadow = '0 0 0 2px #fff,0 0 0 4px var(--swatch-ring,#e0689a)';
            const hidden = document.getElementById(`color-${pid}`);
            if (hidden) hidden.value = name;
            const label = document.getElementById(`color-label-${pid}`);
            if (label) label.textContent = name;
            const img = document.getElementById(`img-${pid}`);
            const src = sw.getAttribute('data-image');
            if (img && src && img.getAttribute('src') !== src) {
              img.style.opacity = '0';
              const swap = new Image();
              swap.onload = () => { img.src = src; img.style.opacity = '1'; };
              swap.src = src;
            }
          });
        });
        // Front/Back view toggle (jerseys etc.)
        const paintView = (btn) => {
          const on = btn.getAttribute('data-active') === 'true';
          btn.style.background = on ? '#e0689a' : 'transparent';
          btn.style.color = on ? '#fff' : '#6e6874';
        };
        document.querySelectorAll('.view-btn').forEach((btn) => {
          paintView(btn);
          btn.addEventListener('click', () => {
            const pid = btn.getAttribute('data-product');
            document.querySelectorAll(`.view-btn[data-product="${pid}"]`).forEach((b) => {
              b.setAttribute('data-active', b === btn ? 'true' : 'false'); paintView(b);
            });
            const img = document.getElementById(`img-${pid}`);
            const src = btn.getAttribute('data-view');
            if (img && src && img.getAttribute('src') !== src) {
              img.style.opacity = '0';
              const swap = new Image();
              swap.onload = () => { img.src = src; img.style.opacity = '1'; };
              swap.src = src;
            }
          });
        });
        // Before add-to-cart, copy the chosen size + colour into Snipcart fields.
        document.querySelectorAll('.snipcart-add-item').forEach((btn) => {
          btn.addEventListener('click', () => {
            const sizeSel = btn.getAttribute('data-size-select');
            if (sizeSel) {
              const sel = document.getElementById(sizeSel);
              if (sel) btn.setAttribute('data-item-custom1-value', sel.value);
            }
            const colorInput = btn.getAttribute('data-color-input');
            if (colorInput) {
              const ci = document.getElementById(colorInput);
              if (ci) btn.setAttribute('data-item-custom2-value', ci.value);
            }
            const nameInput = btn.getAttribute('data-name-input');
            if (nameInput) {
              const ni = document.getElementById(nameInput);
              btn.setAttribute('data-item-custom3-value', ni ? ni.value.toUpperCase().trim() : '');
            }
            const numberInput = btn.getAttribute('data-number-input');
            if (numberInput) {
              const ni = document.getElementById(numberInput);
              btn.setAttribute('data-item-custom4-value', ni ? ni.value.replace(/[^0-9]/g, '') : '');
            }
          }, true);
        });
      </script>
    </Fragment>
  )}
</Layout>
